<Window x:Class="IMS.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:IMS.Converters"
        Title="Sign in — IMS · Inventory &amp; Billing ERP"
        Height="780" Width="1100"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        SizeToContent="Manual"
        PreviewKeyDown="LoginWindow_OnPreviewKeyDown">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/LoginResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
            <conv:BoolToVisibilityConverter x:Key="InverseBoolToVis" Invert="True" />
            <Style x:Key="IconText" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="HorizontalAlignment" Value="Center" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="{StaticResource LoginPageBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.15*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Decorative layer (no hit testing) -->
        <Grid Grid.ColumnSpan="2" Panel.ZIndex="0" IsHitTestVisible="False">
            <Ellipse Width="420" Height="420" Margin="-120,-80,0,0"
                     HorizontalAlignment="Left" VerticalAlignment="Top" Opacity="0.35">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#806366F1" Offset="0" />
                        <GradientStop Color="Transparent" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="60" />
                </Ellipse.Effect>
            </Ellipse>
        </Grid>

        <!-- Brand hero -->
        <Border Grid.Column="0" Panel.ZIndex="1"
                Background="{StaticResource LoginHeroGradient}"
                Padding="48,44">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <Border Width="68" Height="68" CornerRadius="18" Margin="0,0,0,22">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#50FFFFFF" Offset="0" />
                                <GradientStop Color="#20FFFFFF" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="IMS" FontSize="20" FontWeight="ExtraBold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Style="{StaticResource LoginEyebrow}" Text="INVENTORY &amp; BILLING ERP" />
                    <TextBlock Style="{StaticResource LoginHeroTitle}" Text="Run your entire" />
                    <TextBlock Style="{StaticResource LoginHeroAccent}" Text="operations from one place" Margin="0,-4,0,0" />
                    <TextBlock Text="{Binding CompanyTagline}" FontSize="15" Foreground="#94A3B8" Margin="0,14,0,0"
                               TextWrapping="Wrap" MaxWidth="420" LineHeight="24" />
                </StackPanel>

                <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,20,0,0">
                    <WrapPanel>
                        <Border Style="{StaticResource LoginModulePill}">
                            <TextBlock Style="{StaticResource LoginModulePillText}" Text="◈  Inventory" />
                        </Border>
                        <Border Style="{StaticResource LoginModulePill}">
                            <TextBlock Style="{StaticResource LoginModulePillText}" Text="◎  Billing" />
                        </Border>
                        <Border Style="{StaticResource LoginModulePill}">
                            <TextBlock Style="{StaticResource LoginModulePillText}" Text="⬡  Production" />
                        </Border>
                        <Border Style="{StaticResource LoginModulePill}">
                            <TextBlock Style="{StaticResource LoginModulePillText}" Text="◇  Finance" />
                        </Border>
                    </WrapPanel>

                    <Grid Margin="0,32,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="24/7" FontSize="22" FontWeight="Bold" Foreground="White" />
                            <TextBlock Text="LIVE STOCK SYNC" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="GST" FontSize="22" FontWeight="Bold" Foreground="White" />
                            <TextBlock Text="READY INVOICING" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Multi" FontSize="22" FontWeight="Bold" Foreground="White" />
                            <TextBlock Text="WAREHOUSE" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="0,4,0,0" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="2" VerticalAlignment="Bottom">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Ellipse Width="8" Height="8" Fill="#34D399" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="Enterprise-grade · Secure sign-in" FontSize="12" Foreground="#818CF8" />
                    </StackPanel>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Connection"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#64748B"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding ConnectionProfileDisplay}"
                                   FontSize="11"
                                   Foreground="#94A3B8"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="API Link"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#64748B"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding ApiLinkDisplay}"
                                   FontSize="11"
                                   Foreground="#94A3B8"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding ApiLinkDisplay}" />
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Db Name"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#64748B"
                                   Margin="0,6,0,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding DbNameDisplay}"
                                   FontSize="11"
                                   Foreground="#94A3B8"
                                   Margin="0,6,0,0"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding DbNameDisplay}" />
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sign-in panel -->
        <Grid Grid.Column="1" Panel.ZIndex="2" Margin="28,24"
              KeyDown="LoginPanel_OnKeyDown">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource LoginGhostButton}"
                        Command="{Binding ToggleDarkModeCommand}"
                        ToolTip="Toggle light / dark mode">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource IconText}" Text="&#xE708;" Margin="0,0,6,0"
                                   Foreground="{DynamicResource LoginTextMutedBrush}" />
                        <TextBlock Text="{Binding DarkModeToggleLabel}"
                                   Foreground="{DynamicResource LoginTextMutedBrush}" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource LoginCloseButton}"
                        Margin="10,0,0,0"
                        Click="CloseButton_OnClick"
                        ToolTip="Close application">
                    <TextBlock Style="{StaticResource IconText}"
                               Text="&#xE8BB;"
                               FontSize="12"
                               Foreground="{DynamicResource LoginTextMutedBrush}" />
                </Button>
            </StackPanel>

            <Border Grid.Row="1"
                    Style="{StaticResource LoginGlassCard}"
                    Width="460"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Sign in" FontSize="32" FontWeight="Bold"
                               Foreground="{DynamicResource LoginTextBrush}" />
                    <TextBlock Text="{Binding CompanyName, StringFormat=Access {0}}"
                               FontSize="16"
                               Foreground="{DynamicResource LoginTextMutedBrush}"
                               Margin="0,8,0,28"
                               TextWrapping="Wrap" />

                    <Border CornerRadius="8"
                            Padding="10,6"
                            Margin="0,0,0,12"
                            BorderBrush="{DynamicResource LoginFieldBorderBrush}"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#EF4444" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsApiConnected}" Value="True">
                                                <Setter Property="Fill" Value="#22C55E" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding ApiStatusText}"
                                       FontSize="12"
                                       Foreground="{DynamicResource LoginTextMutedBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Background="#FFF7ED"
                            BorderBrush="#FDBA74"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12,10"
                            Margin="0,0,0,16"
                            Visibility="{Binding ShowLicenseNotice, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource IconText}"
                                       Text="&#xE7BA;"
                                       Foreground="#EA580C"
                                       FontSize="14"
                                       Margin="0,0,8,0" />
                            <TextBlock Text="{Binding LicenseStatusMessage}"
                                       FontSize="12"
                                       Foreground="#9A3412"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource LoginErrorBgBrush}"
                            CornerRadius="10"
                            Padding="12,10"
                            Margin="0,0,0,16"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource IconText}"
                                       Text="&#xE783;"
                                       Foreground="{DynamicResource LoginErrorBrush}"
                                       FontSize="14"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Top" />
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="{DynamicResource LoginErrorBrush}"
                                       TextWrapping="Wrap"
                                       FontSize="13" />
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource LoginFieldLabel}" Text="FINANCIAL YEAR" />
                    <Border Height="54"
                            CornerRadius="12"
                            BorderThickness="1.5"
                            SnapsToDevicePixels="True"
                            Margin="0,0,0,12">
                        <ComboBox Style="{x:Null}"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  FontSize="16"
                                  Padding="12,0"
                                  VerticalContentAlignment="Center"
                                  ItemsSource="{Binding FinancialYears}"
                                  SelectedItem="{Binding SelectedFinancialYear}"
                                  DisplayMemberPath="FinancialYearName"
                                  IsEnabled="{Binding IsInputEnabled}" />
                    </Border>

                    <TextBlock Style="{StaticResource LoginFieldLabel}" Text="EMPLOYEE ID OR EMAIL" />
                    <Border x:Name="LoginIdBorder"
                            Height="54"
                            CornerRadius="12"
                            BorderThickness="1.5"
                            SnapsToDevicePixels="True">
                        <TextBox x:Name="LoginIdBox"
                                 Style="{x:Null}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="16"
                                 Padding="16,0"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding LoginId, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsInputEnabled}" />
                    </Border>

                    <TextBlock Style="{StaticResource LoginFieldLabel}" Text="PASSWORD" Margin="0,20,0,0" />
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="PasswordBorder"
                                Grid.Column="0"
                                Height="54"
                                CornerRadius="12"
                                BorderThickness="1.5"
                                SnapsToDevicePixels="True"
                                Visibility="{Binding ShowPassword, Converter={StaticResource InverseBoolToVis}}">
                            <PasswordBox x:Name="PasswordBox"
                                         Style="{x:Null}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontSize="16"
                                         Padding="16,0"
                                         VerticalContentAlignment="Center"
                                         IsEnabled="{Binding IsInputEnabled}"
                                         PasswordChanged="PasswordBox_OnPasswordChanged" />
                        </Border>
                        <Border x:Name="PasswordTextBorder"
                                Grid.Column="0"
                                Height="54"
                                CornerRadius="12"
                                BorderThickness="1.5"
                                SnapsToDevicePixels="True"
                                Visibility="{Binding ShowPassword, Converter={StaticResource BoolToVis}}">
                            <TextBox x:Name="PasswordTextBox"
                                     Style="{x:Null}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="16"
                                     Padding="16,0"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsInputEnabled}" />
                        </Border>
                        <Button Grid.Column="1"
                                Style="{StaticResource LoginIconButton}"
                                Margin="10,0,0,0"
                                Command="{Binding TogglePasswordCommand}"
                                ToolTip="Show or hide password">
                            <TextBlock Style="{StaticResource IconText}"
                                       Text="{Binding PasswordRevealGlyph}"
                                       FontSize="18"
                                       Foreground="{DynamicResource LoginTextMutedBrush}" />
                        </Button>
                    </Grid>

                    <Grid Margin="0,22,0,26">
                        <CheckBox Content="Remember me"
                                  IsChecked="{Binding RememberMe}"
                                  Foreground="{DynamicResource LoginTextBrush}"
                                  FontSize="15"
                                  VerticalAlignment="Center" />
                    </Grid>

                    <Button x:Name="SignInButton"
                            Style="{StaticResource LoginPrimaryButton}"
                            Height="56"
                            IsDefault="True"
                            Command="{Binding LoginCommand}"
                            Click="SignInButton_OnClick"
                            IsEnabled="{Binding IsInputEnabled}">
                        <Grid>
                            <TextBlock Text="Sign in to ERP"
                                       FontSize="17"
                                       HorizontalAlignment="Center"
                                       Visibility="{Binding IsLoggingIn, Converter={StaticResource InverseBoolToVis}}" />
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Visibility="{Binding IsLoggingIn, Converter={StaticResource BoolToVis}}">
                                <TextBlock Style="{StaticResource IconText}"
                                           Text="&#xE1CD;"
                                           FontSize="16"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="Signing in…" FontSize="17" />
                            </StackPanel>
                        </Grid>
                    </Button>

                    <TextBlock Text="Protected workspace. Contact your administrator for access."
                               FontSize="11"
                               Foreground="{DynamicResource LoginTextMutedBrush}"
                               TextWrapping="Wrap"
                               Margin="0,22,0,0"
                               TextAlignment="Center"
                               LineHeight="16" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
