<UserControl x:Class="IMS.Views.FinancialYearManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:IMS.Views.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="760" d:DesignWidth="1100"
             Background="{StaticResource TransactionPageBackgroundBrush}">

    <controls:TransactionEntryShell Title="{Binding Title}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{Binding Description}"
                       Style="{StaticResource PageSubtitle}"
                       Margin="0,0,0,10" />

            <WrapPanel Grid.Row="1" Margin="0,0,0,10">
                <Button Style="{StaticResource ActionButton}" Content="Refresh" Margin="0,0,8,8"
                        Command="{Binding RefreshCommand}" />
                <Button Style="{StaticResource ActionButton}" Content="Create year" Margin="0,0,8,8"
                        Command="{Binding CreateYearCommand}" />
                <Button Style="{StaticResource ActionButton}" Content="Run year-end" Margin="0,0,8,8"
                        Command="{Binding YearEndCommand}" />
                <Button Style="{StaticResource ActionButton}" Content="Delete year" Margin="0,0,8,8"
                        Command="{Binding DeleteYearCommand}" />
            </WrapPanel>

            <Border Grid.Row="2" Style="{StaticResource TransactionSectionBorder}" Padding="12,10">
                <DataGrid ItemsSource="{Binding Years}"
                          SelectedItem="{Binding SelectedYear}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Financial Year" Binding="{Binding FinancialYearName}" Width="*" />
                        <DataGridTextColumn Header="Start" Binding="{Binding StartDate, StringFormat=d}" Width="140" />
                        <DataGridTextColumn Header="End" Binding="{Binding EndDate, StringFormat=d}" Width="140" />
                        <DataGridTextColumn Header="Database" Binding="{Binding DatabaseName}" Width="160" />
                        <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="90" />
                        <DataGridCheckBoxColumn Header="Closed" Binding="{Binding Closed}" Width="90" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,10,0,0" />
        </Grid>
    </controls:TransactionEntryShell>
</UserControl>

