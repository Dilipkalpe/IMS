<UserControl x:Class="IMS.Views.RoleFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:IMS.Views.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="760" d:DesignWidth="1100"
             Background="{StaticResource TransactionPageBackgroundBrush}">

    <UserControl.Resources>
        <Style x:Key="PermissionCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="DetailPermissionCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource PermissionCheckBoxStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding CanSetDetailPermissions}" Value="False">
                    <Setter Property="IsEnabled" Value="False" />
                    <Setter Property="Opacity" Value="0.45" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CanView}" Value="False">
                    <Setter Property="IsEnabled" Value="False" />
                    <Setter Property="Opacity" Value="0.45" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <controls:TransactionEntryShell Title="{Binding PageTitle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{Binding PageDescription}" Style="{StaticResource PageSubtitle}" Margin="0,0,0,12" />

            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Role name" VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBox Grid.Column="1" Text="{Binding RoleName, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding CanEditRoleFields}" />
                <CheckBox Grid.Column="3" Content="Active" IsChecked="{Binding IsActive}" VerticalAlignment="Center"
                          IsEnabled="{Binding CanEditRoleFields}" />
            </Grid>

            <Grid Grid.Row="2" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding MenuFilterText, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,8,0"
                         ToolTip="Filter menus by name (includes matching child menus and their parents)" />
                <WrapPanel Grid.Column="1">
                    <Button Style="{StaticResource ActionButton}" Content="Clear filter" Margin="0,0,8,0"
                            Command="{Binding ClearMenuFilterCommand}" />
                    <Button Style="{StaticResource ActionButton}" Content="Select all View" Margin="0,0,8,0"
                            Command="{Binding SelectAllViewCommand}" />
                    <Button Style="{StaticResource ActionButton}" Content="Clear all"
                            Command="{Binding ClearAllPermissionsCommand}" />
                </WrapPanel>
            </Grid>

            <Border Grid.Row="3" Style="{StaticResource TransactionSectionBorder}" Padding="8,6">
                <Grid>
                    <DataGrid ItemsSource="{Binding PermissionRowsView}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeight="34"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSection}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource PanelMutedBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Menu" Width="2*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding MenuName}"
                                                   Margin="{Binding MenuNameMargin}"
                                                   FontWeight="{Binding MenuNameWeight}"
                                                   VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="View" Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsThreeState="True"
                                                  IsChecked="{Binding ViewCheckState, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource PermissionCheckBoxStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridCheckBoxColumn Header="Add" Binding="{Binding CanAdd, UpdateSourceTrigger=PropertyChanged}" Width="70"
                                                    ElementStyle="{StaticResource DetailPermissionCheckBoxStyle}" />
                            <DataGridCheckBoxColumn Header="Edit" Binding="{Binding CanEdit, UpdateSourceTrigger=PropertyChanged}" Width="70"
                                                    ElementStyle="{StaticResource DetailPermissionCheckBoxStyle}" />
                            <DataGridCheckBoxColumn Header="Delete" Binding="{Binding CanDelete, UpdateSourceTrigger=PropertyChanged}" Width="70"
                                                    ElementStyle="{StaticResource DetailPermissionCheckBoxStyle}" />
                            <DataGridCheckBoxColumn Header="Export" Binding="{Binding CanExport, UpdateSourceTrigger=PropertyChanged}" Width="70"
                                                    ElementStyle="{StaticResource DetailPermissionCheckBoxStyle}" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Panel.ZIndex="10" Style="{StaticResource ListBusyLoadingHost}"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                        <controls:ListLoadingOverlay Title="Loading permissions…" Subtitle="Please wait" />
                    </Border>
                </Grid>
            </Border>

            <DockPanel Grid.Row="4" Margin="0,10,0,0">
                <TextBlock DockPanel.Dock="Right"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="{Binding FilteredRowCount, StringFormat={}{0} row(s) shown}" />
                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="{Binding StatusMessage}"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>

            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Style="{StaticResource ActionButton}" Content="Cancel" Margin="0,0,8,0" Command="{Binding CancelCommand}" />
                <Button Style="{StaticResource PrimaryButton}" Content="Save" Command="{Binding SaveCommand}" />
            </StackPanel>
        </Grid>
    </controls:TransactionEntryShell>
</UserControl>
