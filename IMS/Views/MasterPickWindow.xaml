<Window x:Class="IMS.Views.MasterPickWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:IMS.Views"
        Width="820" Height="520"
        MinWidth="640" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource TransactionPageBackgroundBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/IMS;component/Resources/AppResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding HelpText}"
                   TextWrapping="Wrap" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" />

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MaxWidth="420" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource FormInput}" Height="32"
                     ToolTip="Type to search — results update automatically" />
            <Button Grid.Column="1" Content="Search" Margin="8,0,0,0" MinWidth="80" Height="32"
                    Style="{StaticResource SecondaryButton}" Command="{Binding SearchCommand}" />
        </Grid>

        <Border Grid.Row="2" BorderBrush="{StaticResource TransactionGridBorderBrush}"
                BorderThickness="1" Background="White">
            <DataGrid x:Name="PickGrid"
                      ItemsSource="{Binding Rows}"
                      SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      RowHeight="28"
                      FontSize="12"
                      MouseDoubleClick="PickGrid_OnMouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Sr." Binding="{Binding RowNumber}" Width="48" />
                    <DataGridTextColumn x:Name="CodeColumn" Binding="{Binding Code}" Width="140" />
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" MinWidth="180" />
                    <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="180" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <views:PaginationBar Grid.Row="3" DataContext="{Binding}" Margin="0,4,0,0" />

        <DockPanel Grid.Row="4" Margin="0,12,0,0" LastChildFill="True">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Select" MinWidth="96" Height="32" Margin="0,0,8,0"
                        Style="{StaticResource PrimaryButton}" Command="{Binding SelectCommand}"
                        IsDefault="True" />
                <Button Content="Cancel" MinWidth="96" Height="32"
                        Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}"
                        IsCancel="True" />
            </StackPanel>
            <TextBlock VerticalAlignment="Center" Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource DangerBrush}" TextTrimming="CharacterEllipsis" />
        </DockPanel>
    </Grid>
</Window>
