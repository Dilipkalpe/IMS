<Window x:Class="IMS.Views.InvoiceCommunicationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Send Invoice Notification"
        Height="340" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Border Padding="24" Background="{DynamicResource CardBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Send notification after save?"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8" />
            <TextBlock Grid.Row="1"
                       Text="Choose which channels to use. Only services enabled in Settings are listed."
                       TextWrapping="Wrap" FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,16" />

            <StackPanel Grid.Row="2" x:Name="ChannelPanel" Margin="0,0,0,16" />

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Skip" MinWidth="88" Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButton}" IsCancel="True" Click="Skip_OnClick" />
                <Button Content="Send Now" MinWidth="100"
                        Style="{StaticResource PrimaryButton}" IsDefault="True" Click="Send_OnClick" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
