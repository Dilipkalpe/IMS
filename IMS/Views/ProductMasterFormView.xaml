<UserControl x:Class="IMS.Views.ProductMasterFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:IMS.Models"
             xmlns:converters="clr-namespace:IMS.Converters"
             xmlns:controls="clr-namespace:IMS.Views.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="760" d:DesignWidth="1100"
             VerticalAlignment="Stretch"
             Background="{StaticResource TransactionPageBackgroundBrush}">
    <UserControl.Resources>
        <converters:FormFieldKindToVisibilityConverter x:Key="VisText" TargetKind="{x:Static models:FormFieldKind.Text}" />
        <converters:FormFieldKindToVisibilityConverter x:Key="VisNumber" TargetKind="{x:Static models:FormFieldKind.Number}" />
        <converters:FormFieldKindToVisibilityConverter x:Key="VisCombo" TargetKind="{x:Static models:FormFieldKind.Combo}" />

        <DataTemplate x:Key="ProductMasterFieldTemplate">
            <Border Style="{StaticResource ProductMasterFieldCell}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding DisplayLabel}" Style="{StaticResource ProductMasterFieldLabel}"
                               ToolTip="{Binding ToolTip}" />

                    <Grid Grid.Row="1">
                        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ProductMasterInput}"
                                 Visibility="{Binding Kind, Converter={StaticResource VisText}}" />
                        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ProductMasterInput}"
                                 Visibility="{Binding Kind, Converter={StaticResource VisNumber}}" />

                        <ComboBox ItemsSource="{Binding Options}"
                                  SelectedItem="{Binding SelectedOption, Mode=TwoWay}"
                                  Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True"
                                  Style="{StaticResource ProductMasterCombo}"
                                  Visibility="{Binding Kind, Converter={StaticResource VisCombo}}" />
                    </Grid>

                    <TextBlock Grid.Row="2" Text="{Binding ValidationMessage}" Style="{StaticResource ProductMasterValidation}" />
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <controls:TransactionEntryShell Title="{Binding PageTitle}">
        <Grid Margin="0" VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{Binding PageDescription}" Style="{StaticResource PageSubtitle}" Margin="0,0,0,10" />

            <WrapPanel Grid.Row="1" Margin="0,0,0,10">
                <Button Style="{StaticResource ActionButton}" Content="Manage fields" Margin="0,0,8,8"
                        Command="{Binding ManageFieldsCommand}" />
                <Button Style="{StaticResource ActionButton}" Content="Show all" Margin="0,0,8,8"
                        Command="{Binding ShowAllFieldsCommand}" />
                <Button Style="{StaticResource ActionButton}" Content="Hide optional" Margin="0,0,8,8"
                        Command="{Binding HideOptionalFieldsCommand}" />
                <Button Style="{StaticResource ActionButton}" Content="Reset layout" Margin="0,0,8,8"
                        Command="{Binding ResetLayoutCommand}" />
                <Button Style="{StaticResource ActionButton}" Content="Save layout" Margin="0,0,8,8"
                        Command="{Binding SaveLayoutCommand}" />
            </WrapPanel>

            <Border Grid.Row="2" Style="{StaticResource TransactionSectionBorder}" Padding="12,10" VerticalAlignment="Stretch">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Basic information" Style="{StaticResource SubPageSectionHeader}" />
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding BasicFields}" ItemTemplate="{StaticResource ProductMasterFieldTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" Margin="0,6,0,0" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <TextBlock Grid.Row="2" Text="Pricing, quantity &amp; tax" Style="{StaticResource SubPageSectionHeader}" Margin="0,10,0,4" />
                        <ItemsControl Grid.Row="3" ItemsSource="{Binding PricingFields}" ItemTemplate="{StaticResource ProductMasterFieldTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4" Margin="0,6,0,0" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <TextBlock Grid.Row="4" Text="Classification &amp; UOM + image &amp; options" Style="{StaticResource SubPageSectionHeader}" Margin="0,10,0,4" />

                        <Grid Margin="0,6,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Classification &amp; UOM" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                            <ItemsControl Grid.Row="1" ItemsSource="{Binding ClassificationFields}" ItemTemplate="{StaticResource ProductMasterFieldTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="3" Margin="0,0,0,6" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>

                            <Grid Grid.Row="2" Margin="0,6,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Image &amp; options" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />

                                <StackPanel Grid.Row="1">
                                    <TextBlock Text="Product image path" Style="{StaticResource SubPageFormLabel}" Margin="0,0,0,4" />

                                    <ContentControl Content="{Binding ProductImageField}" Margin="0,0,0,8">
                                        <ContentControl.ContentTemplate>
                                            <DataTemplate DataType="{x:Type models:FormFieldViewModel}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <TextBox Grid.Row="0" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource SubPageFormInput}" />
                                                    <Button Grid.Row="1" Content="Browse image"
                                                            Style="{StaticResource SecondaryButton}" Height="30" Margin="0,6,0,0"
                                                            Command="{Binding DataContext.BrowseFieldCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ContentControl.ContentTemplate>
                                    </ContentControl>

                                    <StackPanel Orientation="Horizontal">
                                        <ContentControl Content="{Binding SerialApplicableField}" Margin="0,0,24,0">
                                            <ContentControl.ContentTemplate>
                                                <DataTemplate DataType="{x:Type models:FormFieldViewModel}">
                                                    <CheckBox IsChecked="{Binding BoolValue, Mode=TwoWay}" Content="Serial Applicable"
                                                              ToolTip="{Binding ToolTip}" FontSize="11" />
                                                </DataTemplate>
                                            </ContentControl.ContentTemplate>
                                        </ContentControl>

                                        <ContentControl Content="{Binding GstExemptField}" Margin="0,0,24,0">
                                            <ContentControl.ContentTemplate>
                                                <DataTemplate DataType="{x:Type models:FormFieldViewModel}">
                                                    <CheckBox IsChecked="{Binding BoolValue, Mode=TwoWay}" Content="GST Exempt"
                                                              ToolTip="{Binding ToolTip}" FontSize="11" />
                                                </DataTemplate>
                                            </ContentControl.ContentTemplate>
                                        </ContentControl>

                                        <ContentControl Content="{Binding ActiveStatusField}">
                                            <ContentControl.ContentTemplate>
                                                <DataTemplate DataType="{x:Type models:FormFieldViewModel}">
                                                    <CheckBox IsChecked="{Binding BoolValue, Mode=TwoWay}" Content="Active"
                                                              ToolTip="{Binding ToolTip}" FontSize="11" />
                                                </DataTemplate>
                                            </ContentControl.ContentTemplate>
                                        </ContentControl>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,16,0,0" HorizontalAlignment="Right">
                            <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}" MinWidth="110" Margin="0,0,10,0">
                                <TextBlock Text="Cancel" FontSize="12" />
                            </Button>
                            <Button Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}" MinWidth="130">
                                <TextBlock Text="Save product" Foreground="White" FontWeight="SemiBold" FontSize="12" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>
    </controls:TransactionEntryShell>
</UserControl>
