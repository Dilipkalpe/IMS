<UserControl x:Class="IMS.Views.SalesAnalysisReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:IMS.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1200"
             VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
             Background="{DynamicResource ContentBackgroundBrush}">
    <UserControl.Resources>
        <Style x:Key="SalesAnalysisTotalRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource SoListRowStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsTotal}" Value="True">
                    <Setter Property="Background" Value="#f1f3f6" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <views:StandardReportView>
        <views:StandardReportView.FilterContent>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,10">
                    <TextBlock Text="Product Code" Style="{StaticResource SoListReportFieldLabel}" />
                    <TextBox Text="{Binding FilterProductCode, UpdateSourceTrigger=PropertyChanged}" Padding="8,6" FontSize="13" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,12,10">
                    <TextBlock Text="Product Name" Style="{StaticResource SoListReportFieldLabel}" />
                    <TextBox Text="{Binding FilterProductName, UpdateSourceTrigger=PropertyChanged}" Padding="8,6" FontSize="13" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,12,10">
                    <TextBlock Text="Main Group" Style="{StaticResource SoListReportFieldLabel}" />
                    <ComboBox ItemsSource="{Binding MainGroupOptions}" SelectedItem="{Binding FilterMainName}"
                              Padding="8,6" FontSize="13" Style="{StaticResource FormCombo}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="Customer" Style="{StaticResource SoListReportFieldLabel}" />
                    <TextBox Text="{Binding FilterCustomer, UpdateSourceTrigger=PropertyChanged}" Padding="8,6" FontSize="13" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="Date From" Style="{StaticResource SoListReportFieldLabel}" />
                    <DatePicker SelectedDate="{Binding DateFrom, Mode=TwoWay}" Height="32" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,12,0">
                    <TextBlock Text="Date To" Style="{StaticResource SoListReportFieldLabel}" />
                    <DatePicker SelectedDate="{Binding DateTo, Mode=TwoWay}" Height="32" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Style="{StaticResource SoListReportShowButton}" Command="{Binding ShowCommand}" />
                </StackPanel>
            </Grid>
        </views:StandardReportView.FilterContent>

        <views:StandardReportView.GridContent>
            <DataGrid ItemsSource="{Binding Rows}"
                      Style="{StaticResource SoListOrdersGrid}"
                      ColumnHeaderStyle="{StaticResource SoListColumnHeader}"
                      RowStyle="{StaticResource SalesAnalysisTotalRowStyle}"
                      CellStyle="{StaticResource SoListDataGridCell}"
                      AlternationCount="2"
                      MinRowHeight="42"
                      ColumnHeaderHeight="44"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding SerialNo}" Width="52">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListCell}">
                                <Setter Property="HorizontalAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="SKU" Binding="{Binding ProductId}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*" MinWidth="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Customer(s)" Binding="{Binding Customer}" Width="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Main Group" Binding="{Binding MainGroup}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Qty" Binding="{Binding QtyDisplay}" Width="75">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListAmountCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Revenue" Binding="{Binding RevenueDisplay}" Width="95">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListAmountCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Discount" Binding="{Binding DiscountDisplay}" Width="85">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListAmountCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="COGS" Binding="{Binding CogsDisplay}" Width="85">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListAmountCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Gross Profit" Binding="{Binding GrossProfitDisplay}" Width="95">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListAmountCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Margin %" Binding="{Binding MarginPctDisplay}" Width="85">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListAmountCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Invoices" Binding="{Binding InvoiceCount}" Width="65">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListAmountCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </views:StandardReportView.GridContent>
    </views:StandardReportView>
</UserControl>
