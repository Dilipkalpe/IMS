<UserControl x:Class="IMS.Views.StockTransferView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:IMS.Views.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1200"
             VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
             Background="{StaticResource TransactionPageBackgroundBrush}">
    <controls:TransactionEntryShell Title="Stock Transfer">
        <controls:TransactionEntryShell.TitleRightHeader>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Current Stock :" FontWeight="Bold" Foreground="Red" FontSize="12" />
                <TextBlock Text="{Binding CurrentStockDisplay}" FontWeight="Bold" Foreground="Red"
                           FontSize="12" Margin="6,0,0,0" />
            </StackPanel>
        </controls:TransactionEntryShell.TitleRightHeader>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" MinHeight="200" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header fields -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Entry No" Style="{StaticResource TransactionInlineFieldLabel}" />
                        <TextBox Grid.Column="1" Text="{Binding EntryNo, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SubPageFormInput}" Height="26" />
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="From Godown" Style="{StaticResource TransactionInlineFieldLabel}" />
                        <ComboBox Grid.Column="1" ItemsSource="{Binding Godowns}" SelectedItem="{Binding FromGodown, Mode=TwoWay}"
                                  Style="{StaticResource SubPageFormCombo}" Height="26" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Remark" Style="{StaticResource TransactionInlineFieldLabel}" VerticalAlignment="Top" Margin="0,4,0,0" />
                        <TextBox Grid.Column="1" Text="{Binding Remark, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SubPageFormMultiline}" Height="60" />
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Transfer Date" Style="{StaticResource TransactionInlineFieldLabel}" />
                        <DatePicker Grid.Column="1" SelectedDate="{Binding TransferDate, Mode=TwoWay}" Height="26" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="To Godown" Style="{StaticResource TransactionInlineFieldLabel}" />
                        <ComboBox Grid.Column="1" ItemsSource="{Binding Godowns}" SelectedItem="{Binding ToGodown, Mode=TwoWay}"
                                  Style="{StaticResource SubPageFormCombo}" Height="26" />
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- Barcode / product scan -->
            <Border Grid.Row="1" Style="{StaticResource TransactionScanBar}" Margin="0,0,0,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" MinWidth="200" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Barcode / Product" Style="{StaticResource SalesFieldLabel}" Margin="0,0,8,0" />
                    <TextBox Grid.Column="1"
                             Text="{Binding BarcodeOrProduct, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SalesCompactInput}"
                             ToolTip="Scan barcode or type product name/code, then press Enter">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding AddLineFromScanCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                </Grid>
            </Border>

            <!-- Line grid -->
            <Border Grid.Row="2" Padding="0" VerticalAlignment="Stretch"
                    BorderBrush="{StaticResource TransactionGridBorderBrush}" BorderThickness="1" Background="White">
                <DataGrid Style="{StaticResource TransactionLineGrid}"
                          ItemsSource="{Binding LineItems}"
                      SelectionUnit="Cell"
                      SelectionMode="Single">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource TransactionLineGridColumnHeader}" />
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource TransactionLineGridCell}" />
                    </DataGrid.CellStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource TransactionLineGridRow}" />
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="40" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button ToolTip="Delete line" Width="28" Height="24" Padding="0" Margin="2,0"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Background="{DynamicResource DangerLightBrush}"
                                            BorderBrush="{DynamicResource DangerBorderBrush}" BorderThickness="1"
                                            Cursor="Hand"
                                            Command="{Binding DataContext.DeleteLineCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="&#xE74D;" FontFamily="{StaticResource IconFont}" FontSize="13"
                                                   Foreground="{DynamicResource DangerBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="SrNo" Binding="{Binding SrNo}" Width="50" IsReadOnly="True" />
                        <DataGridTextColumn Header="Product ID" Binding="{Binding ProductId}" Width="90" IsReadOnly="True" />
                        <DataGridTextColumn Header="Product Code" Binding="{Binding ProductCode}" Width="100" IsReadOnly="True" />
                        <DataGridTextColumn Header="Brand Name" Binding="{Binding BrandName}" Width="*" MinWidth="80" IsReadOnly="True" />
                        <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*" MinWidth="100" IsReadOnly="True" />
                        <DataGridTextColumn Header="HSN Code" Binding="{Binding HsnCode}" Width="80" IsReadOnly="True" />
                        <DataGridTextColumn Header="Batch No" Binding="{Binding BatchNo}" Width="80" IsReadOnly="True" />
                        <DataGridTextColumn Header="Exp. Date" Binding="{Binding ExpDate}" Width="90" IsReadOnly="True" />
                        <DataGridTextColumn Header="Qty" Width="60" IsReadOnly="False"
                                            Binding="{Binding Qty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Right" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Padding" Value="2,0" />
                                    <Setter Property="TextAlignment" Value="Right" />
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                    <Setter Property="FontSize" Value="12" />
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Unit" Width="60" IsReadOnly="False"
                                            Binding="{Binding Unit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Padding" Value="2,0" />
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                    <Setter Property="FontSize" Value="12" />
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Footer -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="SAVE" Command="{Binding SaveCommand}" FontWeight="Bold" Cursor="Hand"
                        Padding="30,6" BorderBrush="Black" BorderThickness="2" Background="White" Margin="0,0,8,0" />
                <Button Content="Cancel" Command="{Binding CancelCommand}" Padding="16,6"
                        Style="{StaticResource SalesSideButtonSecondary}" />
            </StackPanel>
        </Grid>
    </controls:TransactionEntryShell>
</UserControl>
