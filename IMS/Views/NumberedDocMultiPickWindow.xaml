<Window x:Class="IMS.Views.NumberedDocMultiPickWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Documents"
        Width="860" Height="520"
        MinWidth="640" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource TransactionPageBackgroundBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/IMS;component/Resources/AppResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="PickDialogButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                <Setter Property="Padding" Value="14,7" />
                <Setter Property="MinHeight" Value="34" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="FontSize" Value="13" />
            </Style>
            <Style x:Key="PickDialogPrimaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                <Setter Property="Padding" Value="14,7" />
                <Setter Property="MinHeight" Value="34" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="FontSize" Value="13" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,8" FontSize="13"
                   Foreground="{DynamicResource TextSecondaryBrush}">
            <Run Text="{Binding PartyLabel, Mode=OneWay}" FontWeight="SemiBold" />
            <Run Text=": " />
            <Run Text="{Binding PartyName, Mode=OneWay}" />
            <LineBreak />
            <Run Text="{Binding Instructions, Mode=OneWay}" />
        </TextBlock>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Select all" MinWidth="96" Margin="0,0,8,0"
                    Style="{StaticResource PickDialogButton}" Command="{Binding SelectAllCommand}" />
            <Button Content="Clear" MinWidth="80"
                    Style="{StaticResource PickDialogButton}" Command="{Binding ClearSelectionCommand}" />
        </StackPanel>

        <Border Grid.Row="2" BorderBrush="{StaticResource TransactionGridBorderBrush}"
                BorderThickness="1" Background="White">
            <DataGrid x:Name="PickGrid" ItemsSource="{Binding Rows}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowHeight="30"
                      FontSize="12">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="Select" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="60" />
                    <DataGridTextColumn x:Name="DocNoColumn" Header="Doc No" Binding="{Binding FormattedDocNo, Mode=OneWay}" Width="120" IsReadOnly="True" />
                    <DataGridTextColumn Header="Date" Binding="{Binding DocDateDisplay, Mode=OneWay}" Width="100" IsReadOnly="True" />
                    <DataGridTextColumn Header="Status" Binding="{Binding StatusDisplay, Mode=OneWay}" Width="140" IsReadOnly="True" />
                    <DataGridTextColumn Header="Party" Binding="{Binding Party, Mode=OneWay}" Width="*" MinWidth="160" IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <DockPanel Grid.Row="3" Margin="0,12,0,0">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Load lines" MinWidth="118" Margin="0,0,8,0"
                        Style="{StaticResource PickDialogPrimaryButton}" Command="{Binding ConfirmCommand}" IsDefault="True" />
                <Button Content="Cancel" MinWidth="96"
                        Style="{StaticResource PickDialogButton}" Command="{Binding CancelCommand}" IsCancel="True" />
            </StackPanel>
            <TextBlock VerticalAlignment="Center" Text="{Binding StatusMessage, Mode=OneWay}"
                       Foreground="{DynamicResource DangerBrush}" TextTrimming="CharacterEllipsis" />
        </DockPanel>
    </Grid>
</Window>
