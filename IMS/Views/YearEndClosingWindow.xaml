<Window x:Class="IMS.Views.YearEndClosingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Year-End Closing"
        Height="400" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource TransactionPageBackgroundBrush}">
    <Border Style="{StaticResource TransactionSectionBorder}" Padding="16" Margin="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                       Text="Year-End Closing Wizard"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>

            <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                       Text="{Binding FromYearLabel}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,12"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="New Financial Year" VerticalAlignment="Center" />
            <TextBox Grid.Row="2" Grid.Column="1" x:Name="ToNameBox" Height="34" Margin="0,4,0,4"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Start Date" VerticalAlignment="Center" />
            <DatePicker Grid.Row="3" Grid.Column="1" x:Name="ToStartPicker" Margin="0,4,0,4"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="End Date" VerticalAlignment="Center" />
            <DatePicker Grid.Row="4" Grid.Column="1" x:Name="ToEndPicker" Margin="0,4,0,4"/>

            <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Style="{StaticResource SecondaryButton}" MinWidth="110" Margin="0,0,10,0" Click="Cancel_Click">
                    <TextBlock Text="Cancel" FontSize="12"/>
                </Button>
                <Button Style="{StaticResource PrimaryButton}" MinWidth="170" Click="Ok_Click">
                    <TextBlock Text="Run Year-End Closing" Foreground="White" FontWeight="SemiBold" FontSize="12"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>

