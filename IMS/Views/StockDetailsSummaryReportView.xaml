<UserControl x:Class="IMS.Views.StockDetailsSummaryReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:IMS.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1200"
             VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
             Background="{DynamicResource ContentBackgroundBrush}">
    <views:StandardReportView>
        <views:StandardReportView.FilterContent>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,10">
                    <TextBlock Text="Product Code" Style="{StaticResource SoListReportFieldLabel}" />
                    <TextBox Text="{Binding FilterProductCode, UpdateSourceTrigger=PropertyChanged}" Padding="8,6" FontSize="13" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,12,10">
                    <TextBlock Text="Product Name" Style="{StaticResource SoListReportFieldLabel}" />
                    <TextBox Text="{Binding FilterProductName, UpdateSourceTrigger=PropertyChanged}" Padding="8,6" FontSize="13" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,12,10">
                    <TextBlock Text="Main Group" Style="{StaticResource SoListReportFieldLabel}" />
                    <ComboBox ItemsSource="{Binding MainGroupOptions}" SelectedItem="{Binding FilterMainName}"
                              Padding="8,6" FontSize="13" Style="{StaticResource FormCombo}" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,12,10">
                    <TextBlock Text="Product Type" Style="{StaticResource SoListReportFieldLabel}" />
                    <ComboBox ItemsSource="{Binding ProductTypeOptions}" SelectedItem="{Binding FilterProductType}"
                              Padding="8,6" FontSize="13" Style="{StaticResource FormCombo}" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox IsChecked="{Binding IncludeZero}" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="Include zero stock items" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="4"
                            Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Style="{StaticResource SoListReportShowButton}" Command="{Binding ShowCommand}" />
                </StackPanel>
            </Grid>
        </views:StandardReportView.FilterContent>

        <views:StandardReportView.GridContent>
            <DataGrid ItemsSource="{Binding Rows}"
                      Style="{StaticResource SoListOrdersGrid}"
                      ColumnHeaderStyle="{StaticResource SoListColumnHeader}"
                      RowStyle="{StaticResource SoListRowStyle}"
                      CellStyle="{StaticResource SoListDataGridCell}"
                      AlternationCount="2"
                      MinRowHeight="42"
                      ColumnHeaderHeight="44"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding SerialNo}" Width="52" />
                    <DataGridTextColumn Header="Product Code" Binding="{Binding ProductCode}" Width="120" />
                    <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*" MinWidth="200" />
                    <DataGridTextColumn Header="Main Group" Binding="{Binding MainGroup}" Width="140" />
                    <DataGridTextColumn Header="Product Type" Binding="{Binding ProductType}" Width="130" />
                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="70" />
                    <DataGridTextColumn Header="On Hand" Binding="{Binding OnHandQtyDisplay}" Width="100" />
                    <DataGridTextColumn Header="Rate" Binding="{Binding PurchaseRateDisplay}" Width="100" />
                    <DataGridTextColumn Header="Value" Binding="{Binding StockValueDisplay}" Width="110" />
                    <DataGridTextColumn Header="Reorder" Binding="{Binding ReorderLevelDisplay}" Width="100" />
                    <DataGridTextColumn Header="Shortage" Binding="{Binding ShortageQtyDisplay}" Width="100" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="130" />
                </DataGrid.Columns>
            </DataGrid>
        </views:StandardReportView.GridContent>
    </views:StandardReportView>
</UserControl>

