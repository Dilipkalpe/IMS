<UserControl x:Class="IMS.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:IMS.Views.Controls"
             xmlns:chartControls="clr-namespace:IMS.Views.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200"
             VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
             Background="{StaticResource TransactionPageBackgroundBrush}">
    <UserControl.Resources>
        <Style x:Key="DashboardSectionHeader" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="CornerRadius" Value="6,6,0,0" />
            <Setter Property="Margin" Value="-12,-10,-12,8" />
            <Setter Property="Padding" Value="10,8" />
        </Style>
        <Style x:Key="DashboardSectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <Style x:Key="DashboardMetricLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        </Style>
        <Style x:Key="DashboardMetricValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
    </UserControl.Resources>
    <controls:TransactionEntryShell Title="{Binding PageTitle}" VerticalAlignment="Stretch"
                                    ContentMargin="0" HorizontalAlignment="Stretch">
        <controls:TransactionEntryShell.TitleRightHeader>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding LastRefreshed}" FontSize="10" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,6,0" />
                <Button Content="Refresh" Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButton}" Padding="8,3" FontSize="11" />
            </StackPanel>
        </controls:TransactionEntryShell.TitleRightHeader>

        <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" MinHeight="500" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.RowSpan="3" Panel.ZIndex="10"
                    Background="{StaticResource TransactionPageBackgroundBrush}"
                    Visibility="{Binding ShowLoadingOverlay, Converter={StaticResource BoolToVisibility}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Loading dashboard…" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="Fetching live figures from the API" FontSize="12" Margin="0,4,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <Border Grid.Row="0" Margin="0,0,0,4" Padding="10,8" CornerRadius="6"
                    Background="{DynamicResource DangerLightBrush}"
                    BorderBrush="{DynamicResource DangerBorderBrush}"
                    BorderThickness="1"
                    Visibility="{Binding ShowApiOfflineBanner, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="{Binding ApiStatusMessage}" FontSize="12" TextWrapping="Wrap" />
            </Border>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding Stats}" Margin="0,2,0,6"
                          HorizontalAlignment="Stretch"
                          Visibility="{Binding ShowDashboardContent, Converter={StaticResource BoolToVisibility}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4" Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                        <Setter Property="VerticalAlignment" Value="Stretch" />
                        <Setter Property="Margin" Value="4,0.2,4,8" />
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:StatCounterCard HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                                  MinHeight="80" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Grid Grid.Row="2"
                  Visibility="{Binding ShowDashboardContent, Converter={StaticResource BoolToVisibility}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="280" />
                    <ColumnDefinition Width="*" MinWidth="280" />
                    <ColumnDefinition Width="*" MinWidth="280" />
                </Grid.ColumnDefinitions>

                <!-- Accounting Overview -->
                <Border Grid.Column="0" Style="{StaticResource DashboardPanelCard}" Margin="0,0,6,0">
                    <DockPanel LastChildFill="True">
                        <Border DockPanel.Dock="Top" Style="{StaticResource DashboardSectionHeader}">
                            <TextBlock Text="Accounting Overview" Style="{StaticResource DashboardSectionTitle}" />
                        </Border>
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource DashboardInnerCard}" Margin="0,0,6,6"><StackPanel><TextBlock Text="{Binding ActivityRows[0].Col1}" Style="{StaticResource DashboardMetricLabel}"/><TextBlock Text="{Binding ActivityRows[0].Col2}" Style="{StaticResource DashboardMetricValue}"/></StackPanel></Border>
                            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource DashboardInnerCard}" Margin="6,0,0,6"><StackPanel><TextBlock Text="{Binding ActivityRows[1].Col1}" Style="{StaticResource DashboardMetricLabel}"/><TextBlock Text="{Binding ActivityRows[1].Col2}" Style="{StaticResource DashboardMetricValue}"/></StackPanel></Border>
                            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource DashboardInnerCard}" Margin="0,6,6,0"><StackPanel><TextBlock Text="{Binding ActivityRows[2].Col1}" Style="{StaticResource DashboardMetricLabel}"/><TextBlock Text="{Binding ActivityRows[2].Col2}" Style="{StaticResource DashboardMetricValue}"/></StackPanel></Border>
                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource DashboardInnerCard}" Margin="6,6,0,0"><StackPanel><TextBlock Text="{Binding ActivityRows[3].Col1}" Style="{StaticResource DashboardMetricLabel}"/><TextBlock Text="{Binding ActivityRows[3].Col2}" Style="{StaticResource DashboardMetricValue}"/></StackPanel></Border>
                        </Grid>
                        <UniformGrid DockPanel.Dock="Bottom" Columns="3" Margin="0,8,0,0">
                            <Button Style="{StaticResource PrimaryButton}" Margin="0,0,4,0" Padding="8,6"
                                    Command="{Binding NavigateQuickLinkCommand}" CommandParameter="sales-invoice">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IconText}" Text="&#xE8A5;" Margin="0,0,4,0" />
                                    <TextBlock Text="Invoice" FontSize="12" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource PrimaryButton}" Margin="2,0" Padding="8,6"
                                    Command="{Binding NavigateQuickLinkCommand}" CommandParameter="purchase-invoice">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IconText}" Text="&#xE719;" Margin="0,0,4,0" />
                                    <TextBlock Text="Purchase" FontSize="12" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource PrimaryButton}" Margin="4,0,0,0" Padding="8,6"
                                    Command="{Binding NavigateQuickLinkCommand}" CommandParameter="payment-voucher">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IconText}" Text="&#xE8C8;" Margin="0,0,4,0" />
                                    <TextBlock Text="Payment" FontSize="12" />
                                </StackPanel>
                            </Button>
                        </UniformGrid>
                        <chartControls:DashboardBarChart Chart="{Binding SalesPurchaseChart}"
                                                          MinHeight="260" VerticalAlignment="Stretch" Margin="0,4,0,0"/>
                    </DockPanel>
                </Border>

                <!-- Inventory Management -->
                <Border Grid.Column="1" Style="{StaticResource DashboardPanelCard}" Margin="3,0">
                    <DockPanel LastChildFill="True">
                        <Border DockPanel.Dock="Top" Style="{StaticResource DashboardSectionHeader}">
                            <TextBlock Text="Inventory Management" Style="{StaticResource DashboardSectionTitle}" />
                        </Border>
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource DashboardInnerCard}" Margin="0,0,6,6"><StackPanel><TextBlock Text="{Binding SummaryLines[0].Label}" Style="{StaticResource DashboardMetricLabel}"/><TextBlock Text="{Binding SummaryLines[0].Value}" Style="{StaticResource DashboardMetricValue}"/></StackPanel></Border>
                            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource DashboardInnerCard}" Margin="6,0,0,6"><StackPanel><TextBlock Text="{Binding SummaryLines[1].Label}" Style="{StaticResource DashboardMetricLabel}"/><TextBlock Text="{Binding SummaryLines[1].Value}" Style="{StaticResource DashboardMetricValue}"/></StackPanel></Border>
                            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource DashboardInnerCard}" Margin="0,6,6,0"><StackPanel><TextBlock Text="{Binding SummaryLines[2].Label}" Style="{StaticResource DashboardMetricLabel}"/><TextBlock Text="{Binding SummaryLines[2].Value}" Style="{StaticResource DashboardMetricValue}"/></StackPanel></Border>
                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource DashboardInnerCard}" Margin="6,6,0,0"><StackPanel><TextBlock Text="{Binding SummaryLines[3].Label}" Style="{StaticResource DashboardMetricLabel}"/><TextBlock Text="{Binding SummaryLines[3].Value}" Style="{StaticResource DashboardMetricValue}"/></StackPanel></Border>
                        </Grid>
                        <UniformGrid DockPanel.Dock="Bottom" Columns="3" Margin="0,8,0,0">
                            <Button Style="{StaticResource PrimaryButton}" Margin="0,0,4,0" Padding="8,6"
                                    Command="{Binding NavigateQuickLinkCommand}" CommandParameter="opening-stock">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IconText}" Text="&#xE74C;" Margin="0,0,4,0" />
                                    <TextBlock Text="Opening Stock" FontSize="12" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource PrimaryButton}" Margin="2,0" Padding="8,6"
                                    Command="{Binding NavigateQuickLinkCommand}" CommandParameter="stock-transfer">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IconText}" Text="&#xE8AB;" Margin="0,0,4,0" />
                                    <TextBlock Text="Stock Transfer" FontSize="12" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource PrimaryButton}" Margin="4,0,0,0" Padding="8,6"
                                    Command="{Binding NavigateQuickLinkCommand}" CommandParameter="closing-stock">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IconText}" Text="&#xE8F2;" Margin="0,0,4,0" />
                                    <TextBlock Text="Closing Stock" FontSize="12" />
                                </StackPanel>
                            </Button>
                        </UniformGrid>
                        <chartControls:DashboardLineChart Chart="{Binding InventoryStockChart}"
                                                          MinHeight="260" VerticalAlignment="Stretch" Margin="0,4,0,0"/>
                    </DockPanel>
                </Border>

                <!-- Production Status -->
                <Border Grid.Column="2" Style="{StaticResource DashboardPanelCard}" Margin="6,0,0,0">
                    <DockPanel LastChildFill="True">
                        <Border DockPanel.Dock="Top" Style="{StaticResource DashboardSectionHeader}">
                            <TextBlock Text="Production Status" Style="{StaticResource DashboardSectionTitle}" />
                        </Border>
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource DashboardInnerCard}" Margin="0,0,6,6"><StackPanel><TextBlock Text="{Binding Alerts[0].Title}" Style="{StaticResource DashboardMetricLabel}"/><TextBlock Text="{Binding Alerts[0].Detail}" Style="{StaticResource DashboardMetricValue}"/></StackPanel></Border>
                            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource DashboardInnerCard}" Margin="6,0,0,6"><StackPanel><TextBlock Text="{Binding Alerts[1].Title}" Style="{StaticResource DashboardMetricLabel}"/><TextBlock Text="{Binding Alerts[1].Detail}" Style="{StaticResource DashboardMetricValue}"/></StackPanel></Border>
                            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource DashboardInnerCard}" Margin="0,6,6,0"><StackPanel><TextBlock Text="{Binding Alerts[2].Title}" Style="{StaticResource DashboardMetricLabel}"/><TextBlock Text="{Binding Alerts[2].Detail}" Style="{StaticResource DashboardMetricValue}"/></StackPanel></Border>
                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource DashboardInnerCard}" Margin="6,6,0,0"><StackPanel><TextBlock Text="{Binding Alerts[3].Title}" Style="{StaticResource DashboardMetricLabel}"/><TextBlock Text="{Binding Alerts[3].Detail}" Style="{StaticResource DashboardMetricValue}"/></StackPanel></Border>
                        </Grid>
                        <UniformGrid DockPanel.Dock="Bottom" Columns="3" Margin="0,8,0,0">
                            <Button Style="{StaticResource PrimaryButton}" Margin="0,0,4,0" Padding="8,6"
                                    Command="{Binding NavigateQuickLinkCommand}" CommandParameter="production-orders">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IconText}" Text="&#xE8FD;" Margin="0,0,4,0" />
                                    <TextBlock Text="Job Work" FontSize="12" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource PrimaryButton}" Margin="2,0" Padding="8,6"
                                    Command="{Binding NavigateQuickLinkCommand}" CommandParameter="products">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IconText}" Text="&#xE710;" Margin="0,0,4,0" />
                                    <TextBlock Text="Add Product" FontSize="12" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource PrimaryButton}" Margin="4,0,0,0" Padding="8,6"
                                    Command="{Binding NavigateQuickLinkCommand}" CommandParameter="account-ledger">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IconText}" Text="&#xE77B;" Margin="0,0,4,0" />
                                    <TextBlock Text="Add Customer" FontSize="12" />
                                </StackPanel>
                            </Button>
                        </UniformGrid>
                        <chartControls:DashboardDonutChart Chart="{Binding StockCategoryChart}"
                                                           MinHeight="260" VerticalAlignment="Stretch" Margin="0,4,0,0"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </controls:TransactionEntryShell>
</UserControl>
