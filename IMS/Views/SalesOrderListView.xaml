<UserControl x:Class="IMS.Views.SalesOrderListView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:IMS.Views.Controls"
             xmlns:views="clr-namespace:IMS.Views"
             xmlns:vm="clr-namespace:IMS.ViewModels"
             xmlns:converters="clr-namespace:IMS.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1280"
             VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
             Background="{DynamicResource ContentBackgroundBrush}">
    <UserControl.Resources>
        <converters:SortGlyphConverter x:Key="SortGlyphConverter" />
        <Style x:Key="SoListColumnHeader" TargetType="DataGridColumnHeader" BasedOn="{StaticResource CorporateDataGridColumnHeader}">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>
        <Style x:Key="SoListRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="{DynamicResource CardBrush}" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentLightBrush}" />
                </Trigger>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="{DynamicResource PanelMutedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SoListSortHeader" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4,6" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentLightBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SoListSortableColumnHeader" TargetType="DataGridColumnHeader" BasedOn="{StaticResource SoListColumnHeader}">
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentLightBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SoListCell" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="ToolTip">
                <Setter.Value>
                    <Binding Path="Text" RelativeSource="{RelativeSource Self}" />
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SoListAmountCell" TargetType="TextBlock" BasedOn="{StaticResource SoListCell}">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>
        <Style x:Key="SoListGridActionButton" TargetType="Button">
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SoListActionPrintButton" TargetType="Button" BasedOn="{StaticResource SoListGridActionButton}">
            <Style.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="White" />
                </Style>
            </Style.Resources>
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SoListActionEditButton" TargetType="Button" BasedOn="{StaticResource SoListGridActionButton}">
            <Style.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                </Style>
            </Style.Resources>
            <Setter Property="Background" Value="{DynamicResource AccentLightBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PanelMutedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SoListActionDeleteButton" TargetType="Button" BasedOn="{StaticResource SoListGridActionButton}">
            <Style.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                </Style>
            </Style.Resources>
            <Setter Property="Background" Value="{DynamicResource DangerLightBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DangerBorderBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SoListSectionBorder" TargetType="Border" BasedOn="{StaticResource TransactionSectionBorder}">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>
        <Style x:Key="SoListOrdersGrid" TargetType="DataGrid" BasedOn="{StaticResource InventoryReportDataGrid}">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="GridLinesVisibility" Value="All" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>
        <Style x:Key="SoListStatCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>
        <Style x:Key="SoListStatIconHost" TargetType="Border">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="CornerRadius" Value="11" />
            <Setter Property="Background" Value="{Binding AccentColor, Converter={StaticResource HexToBrushConverter}}" />
            <Setter Property="BorderBrush" Value="#33FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270" Opacity="0.22"
                                      Color="{DynamicResource Theme.Shadow}" />
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SoListStatIconGlyph" TargetType="TextBlock" BasedOn="{StaticResource IconText}">
            <Setter Property="FontSize" Value="19" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Text" Value="{Binding IconGlyph}" />
        </Style>
        <Style x:Key="SoListDataGridCell" TargetType="DataGridCell">
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ToolTip">
                <Setter.Value>
                    <Binding Path="Content.Text" RelativeSource="{RelativeSource Self}" />
                </Setter.Value>
            </Setter>
            <Setter Property="ToolTipService.InitialShowDelay" Value="250" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentLightBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <controls:TransactionEntryShell Title="{Binding PageTitle}">
        <Grid MinHeight="480">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" MinHeight="320" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.RowSpan="3" Panel.ZIndex="20"
                    Background="{StaticResource TransactionPageBackgroundBrush}"
                    Visibility="{Binding ShowLoadingOverlay, Converter={StaticResource BoolToVisibility}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Loading…" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding LoadingSubtitle}" FontSize="12" Margin="0,6,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"
                               TextWrapping="Wrap" MaxWidth="360" TextAlignment="Center" />
                </StackPanel>
            </Border>

            <ItemsControl Grid.Row="0" ItemsSource="{Binding Stats}" Margin="0,0,0,6"
                          Visibility="{Binding ShowListContent, Converter={StaticResource BoolToVisibility}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,8,0">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource SoListStatCard}">
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Setter Property="BorderBrush"
                                            Value="{Binding AccentColor, Converter={StaticResource HexToBrushConverter}}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Label}" Value="Cancelled">
                                            <Setter Property="Padding" Value="10,8" />
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background"
                                                    Value="{Binding AccentColor, Converter={StaticResource HexToLightBrushConverter}}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="3" Margin="0,2,8,2"
                                        Background="{Binding AccentColor, Converter={StaticResource HexToBrushConverter}}" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Label}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                                    <TextBlock Text="{Binding Value}" FontSize="18" FontWeight="SemiBold"
                                               Foreground="{Binding AccentColor, Converter={StaticResource HexToBrushConverter}}"
                                               Margin="0,2,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Label}" Value="Cancelled">
                                                        <Setter Property="FontSize" Value="20" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <Border Grid.Column="2">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource SoListStatIconHost}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Label}" Value="Cancelled">
                                                    <Setter Property="Width" Value="52" />
                                                    <Setter Property="Height" Value="52" />
                                                    <Setter Property="CornerRadius" Value="12" />
                                                    <Setter Property="BorderThickness" Value="2" />
                                                    <Setter Property="BorderBrush" Value="#66FFFFFF" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListStatIconGlyph}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Label}" Value="Cancelled">
                                                        <Setter Property="FontSize" Value="22" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Grid.Row="1" Style="{StaticResource SoListSectionBorder}" Padding="8,6" Margin="0,0,0,4"
                    Visibility="{Binding ShowListContent, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                        <ItemsControl ItemsSource="{Binding SubPageActions}" Margin="0,0,8,8">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource ActionButton}" Command="{Binding Command}" Margin="0,0,8,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource IconText}" FontSize="14" Text="{Binding IconGlyph}" Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding Title}" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBox Width="220" MinWidth="160" Margin="0,0,8,8"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13"
                                 ToolTip="Search SO no, customer, salesman…" />
                        <ComboBox Width="140" MinWidth="120" Margin="0,0,8,8"
                                  ItemsSource="{Binding StatusFilterOptions}"
                                  SelectedItem="{Binding StatusFilter}"
                                  Style="{StaticResource FormCombo}" />
                        <Button Style="{StaticResource ActionButton}" Command="{Binding RefreshCommand}" Margin="0,0,8,8" Content="Refresh" />
                        <Button Style="{StaticResource ActionButton}" Command="{Binding ManageColumnsCommand}" Margin="0,0,8,8" Content="Manage Columns" />
                        <Button x:Name="ExportDataButton" Style="{StaticResource ActionButton}" Margin="0,0,8,8"
                                Click="OnExportDataClick">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Export Data" />
                                <TextBlock Text="&#xE70D;" Style="{StaticResource IconText}" FontSize="10"
                                           Margin="6,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                    <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                </Grid>
            </Border>

            <Popup x:Name="ExportDataPopup"
                   Placement="Bottom"
                   StaysOpen="True"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <Border x:Name="ExportDataMenuHost"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Padding="4"
                        SnapsToDevicePixels="True">
                    <StackPanel MinWidth="148">
                        <Button Style="{StaticResource ActionButton}" Content="Excel" Margin="0,0,0,2"
                                Padding="12,6" HorizontalContentAlignment="Left"
                                PreviewMouseLeftButtonDown="OnExportExcelClick" />
                        <Button Style="{StaticResource ActionButton}" Content="PDF" Margin="0,0,0,2"
                                Padding="12,6" HorizontalContentAlignment="Left"
                                PreviewMouseLeftButtonDown="OnExportPdfClick" />
                        <Button Style="{StaticResource ActionButton}" Content="Print"
                                Padding="12,6" HorizontalContentAlignment="Left"
                                PreviewMouseLeftButtonDown="OnExportPrintClick" />
                    </StackPanel>
                </Border>
            </Popup>

            <Border Grid.Row="2" Style="{StaticResource SoListSectionBorder}" Padding="1"
                    Visibility="{Binding ShowListContent, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="OrdersGrid"
                              Grid.Row="0"
                              ToolTipService.InitialShowDelay="250"
                              ToolTipService.ShowDuration="120000"
                              ItemsSource="{Binding Rows}"
                              Style="{StaticResource SoListOrdersGrid}"
                              ColumnHeaderStyle="{StaticResource SoListColumnHeader}"
                              RowStyle="{StaticResource SoListRowStyle}"
                              CellStyle="{StaticResource SoListDataGridCell}"
                              AlternationCount="2"
                              MinWidth="720"
                              MinRowHeight="42"
                              ColumnHeaderHeight="44"
                              CanUserReorderColumns="False"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="False"
                              FrozenColumnCount="2"
                              HeadersVisibility="Column"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              VerticalAlignment="Stretch"
                              HorizontalAlignment="Stretch">
                            <DataGrid.Columns>
                                <DataGridTextColumn x:Name="ColSr" Binding="{Binding SerialNo}" Width="52" IsReadOnly="True"
                                                    HeaderStyle="{StaticResource SoListSortableColumnHeader}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SoListCell}">
                                            <Setter Property="HorizontalAlignment" Value="Center" />
                                            <Setter Property="TextWrapping" Value="NoWrap" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.Header>
                                        <Button Style="{StaticResource SoListSortHeader}"
                                                Command="{Binding DataContext.SortColumnCommand, ElementName=Root}"
                                                CommandParameter="sr">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="Sr." />
                                                <TextBlock>
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource SortGlyphConverter}" ConverterParameter="sr">
                                                            <Binding Path="DataContext.CurrentSortField" ElementName="Root" />
                                                            <Binding Path="DataContext.CurrentSortDir" ElementName="Root" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                        </Button>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn x:Name="ColActions" Header="Action" Width="128" MinWidth="110" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,6">
                                                <Button ToolTip="Print" Style="{StaticResource SoListActionPrintButton}"
                                                        Command="{Binding DataContext.PrintRowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Style="{StaticResource IconText}" Text="&#xE749;" FontSize="12" />
                                                </Button>
                                                <Button ToolTip="Edit" Style="{StaticResource SoListActionEditButton}"
                                                        Command="{Binding DataContext.EditRowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Style="{StaticResource IconText}" Text="&#xE70F;" FontSize="12" />
                                                </Button>
                                                <Button ToolTip="Delete" Style="{StaticResource SoListActionDeleteButton}"
                                                        Command="{Binding DataContext.DeleteRowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Style="{StaticResource IconText}" Text="&#xE74D;" FontSize="12" />
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn x:Name="ColSoNo" Binding="{Binding SoNo}" Width="120" MinWidth="90" IsReadOnly="True"
                                                    HeaderStyle="{StaticResource SoListSortableColumnHeader}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SoListCell}">
                                            <Setter Property="TextWrapping" Value="NoWrap" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.Header>
                                        <Button Style="{StaticResource SoListSortHeader}"
                                                Command="{Binding DataContext.SortColumnCommand, ElementName=Root}"
                                                CommandParameter="soNo">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="SO No" />
                                                <TextBlock>
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource SortGlyphConverter}" ConverterParameter="soNo">
                                                            <Binding Path="DataContext.CurrentSortField" ElementName="Root" />
                                                            <Binding Path="DataContext.CurrentSortDir" ElementName="Root" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                        </Button>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTextColumn x:Name="ColSoDate" Binding="{Binding SoDate}" Width="108" MinWidth="88" IsReadOnly="True"
                                                    HeaderStyle="{StaticResource SoListSortableColumnHeader}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SoListCell}">
                                            <Setter Property="TextWrapping" Value="NoWrap" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.Header>
                                        <Button Style="{StaticResource SoListSortHeader}"
                                                Command="{Binding DataContext.SortColumnCommand, ElementName=Root}"
                                                CommandParameter="soDate">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="SO Date" />
                                                <TextBlock>
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource SortGlyphConverter}" ConverterParameter="soDate">
                                                            <Binding Path="DataContext.CurrentSortField" ElementName="Root" />
                                                            <Binding Path="DataContext.CurrentSortDir" ElementName="Root" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                        </Button>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTextColumn x:Name="ColCustomer" Binding="{Binding Customer}" Width="*" MinWidth="120" IsReadOnly="True"
                                                    HeaderStyle="{StaticResource SoListSortableColumnHeader}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SoListCell}" />
                                    </DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.Header>
                                        <Button Style="{StaticResource SoListSortHeader}"
                                                Command="{Binding DataContext.SortColumnCommand, ElementName=Root}"
                                                CommandParameter="customer">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Customer" />
                                                <TextBlock>
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource SortGlyphConverter}" ConverterParameter="customer">
                                                            <Binding Path="DataContext.CurrentSortField" ElementName="Root" />
                                                            <Binding Path="DataContext.CurrentSortDir" ElementName="Root" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                        </Button>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTextColumn x:Name="ColTotalTaxable" Binding="{Binding TotalTaxableDisplay}" Width="130" MinWidth="100" IsReadOnly="True"
                                                    HeaderStyle="{StaticResource SoListSortableColumnHeader}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SoListAmountCell}" />
                                    </DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.Header>
                                        <Button Style="{StaticResource SoListSortHeader}"
                                                Command="{Binding DataContext.SortColumnCommand, ElementName=Root}"
                                                CommandParameter="totalTaxable">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Total Taxable Amount" TextTrimming="CharacterEllipsis" />
                                                <TextBlock>
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource SortGlyphConverter}" ConverterParameter="totalTaxable">
                                                            <Binding Path="DataContext.CurrentSortField" ElementName="Root" />
                                                            <Binding Path="DataContext.CurrentSortDir" ElementName="Root" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                        </Button>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTextColumn x:Name="ColTotalCgst" Binding="{Binding TotalCgstDisplay}" Width="100" IsReadOnly="True"
                                                    HeaderStyle="{StaticResource SoListSortableColumnHeader}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SoListAmountCell}" />
                                    </DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.Header>
                                        <Button Style="{StaticResource SoListSortHeader}"
                                                Command="{Binding DataContext.SortColumnCommand, ElementName=Root}"
                                                CommandParameter="totalCgst">
                                            <StackPanel Orientation="Horizontal">
