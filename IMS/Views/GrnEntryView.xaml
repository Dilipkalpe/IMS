<UserControl x:Class="IMS.Views.GrnEntryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:IMS.Views.Controls"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1200"
             VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
             Background="{StaticResource TransactionPageBackgroundBrush}">
    <controls:TransactionEntryShell Title="Goods Receipt Note (GRN)">
        <Grid Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="232" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource TransactionSectionBorder}" Padding="10" Margin="0,0,6,6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <UniformGrid Grid.Row="0" Columns="5" Rows="2">
                        <StackPanel Style="{StaticResource SubPageFieldCell}">
                            <TextBlock Text="{Binding PrefixFieldLabel}" Style="{StaticResource SubPageFormLabel}" />
                            <TextBox x:Name="DocPrefixBox"
                                     Text="{Binding EntryDocPrefix, UpdateSourceTrigger=LostFocus}"
                                     IsReadOnly="{Binding IsEntryPrefixReadOnly}"
                                     CharacterCasing="Upper" MaxLength="12"
                                     Style="{StaticResource SubPageFormInput}" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource SubPageFieldCell}">
                            <TextBlock Text="GRN No" Style="{StaticResource SubPageFormLabel}" />
                            <TextBox Text="{Binding BillNo, UpdateSourceTrigger=PropertyChanged}"
                                     IsReadOnly="{Binding IsBillNoReadOnly}"
                                     Style="{StaticResource SubPageFormInput}" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource SubPageFieldCell}">
                            <TextBlock Text="GRN Date" Style="{StaticResource SubPageFormLabel}" />
                            <DatePicker SelectedDate="{Binding GrnDate, Mode=TwoWay}" Height="28" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource SubPageFieldCell}">
                            <TextBlock Text="Supplier Name" Style="{StaticResource SubPageFormLabel}" />
                            <ComboBox ItemsSource="{Binding Suppliers}" Text="{Binding Supplier, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True" Style="{StaticResource SubPageFormCombo}" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource SubPageFieldCell}">
                            <TextBlock Text="PO Reference" Style="{StaticResource SubPageFormLabel}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding PoReference, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="True" Style="{StaticResource SubPageFormInput}" Margin="0,0,6,0"
                                         ToolTip="Filled automatically from selected purchase orders" />
                                <Button Grid.Column="1" Content="Load POs"
                                        Style="{StaticResource EntryFormLoadButton}"
                                        Command="{Binding LoadFromPurchaseOrdersCommand}"
                                        ToolTip="Select multiple purchase orders for this supplier" />
                            </Grid>
                        </StackPanel>
                        <StackPanel Style="{StaticResource SubPageFieldCell}">
                            <TextBlock Text="Warehouse" Style="{StaticResource SubPageFormLabel}" />
                            <TextBox Text="{Binding Warehouse, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SubPageFormInput}" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource SubPageFieldCell}">
                            <TextBlock Text="Vehicle No" Style="{StaticResource SubPageFormLabel}" />
                            <TextBox Text="{Binding VehicleNo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SubPageFormInput}" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource SubPageFieldCell}">
                            <TextBlock Text="Transporter" Style="{StaticResource SubPageFormLabel}" />
                            <TextBox Text="{Binding Transporter, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SubPageFormInput}" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource SubPageFieldCell}">
                            <TextBlock Text="Buyer" Style="{StaticResource SubPageFormLabel}" />
                            <ComboBox ItemsSource="{Binding Buyers}" Text="{Binding Buyer, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True" Style="{StaticResource SubPageFormCombo}" />
                        </StackPanel>
                    </UniformGrid>
                    <controls:TransactionPurchaseGstHeaderRow Grid.Row="1" />
                </Grid>
            </Border>

            <controls:SalesInvoiceLineItemsPanel Grid.Row="1" Grid.Column="0" Margin="0,0,6,6" />

            <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource TransactionSectionBorder}" Padding="10" Margin="0,0,6,0">
                <controls:TransactionEntryBottomPanel />
            </Border>

            <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" Style="{StaticResource TransactionTotalsRailHighlightPanel}" Padding="10,8">
                <controls:TransactionGstTotalsRail />
            </Border>
        </Grid>
    </controls:TransactionEntryShell>
</UserControl>
