<UserControl x:Class="IMS.Views.StandardReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:IMS.Views.Controls"
             x:Name="ReportRoot"
             VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
             Background="{DynamicResource ContentBackgroundBrush}">
    <controls:TransactionEntryShell Title="{Binding PageTitle}">
        <Grid MinHeight="480">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" MinHeight="240" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource SoListSectionBorder}" Padding="10,8" Margin="0,0,0,6">
                <ContentPresenter Content="{Binding FilterContent, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </Border>

            <TextBlock Grid.Row="1" Text="{Binding SummaryText}" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"
                       TextWrapping="Wrap" />

            <WrapPanel Grid.Row="2" Margin="0,0,0,6">
                <Button x:Name="ManageColumnsButton"
                        Style="{StaticResource ActionButton}"
                        Margin="0,0,8,8"
                        Content="Manage Columns"
                        Click="ManageColumnsButton_OnClick" />
                <Button x:Name="ExportDataButton"
                        Style="{StaticResource ActionButton}"
                        Margin="0,0,8,8"
                        Click="OnExportDataClick">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Export Data" />
                        <TextBlock Text="&#xE70D;" Style="{StaticResource IconText}" FontSize="10"
                                   Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </WrapPanel>

            <Popup x:Name="ExportDataPopup" Placement="Bottom" StaysOpen="True" AllowsTransparency="True" PopupAnimation="Fade">
                <Border x:Name="ExportDataMenuHost"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Padding="4"
                        SnapsToDevicePixels="True">
                    <StackPanel MinWidth="148">
                        <Button Style="{StaticResource ActionButton}" Content="Excel" Margin="0,0,0,2"
                                Padding="12,6" HorizontalContentAlignment="Left"
                                PreviewMouseLeftButtonDown="OnExportExcelClick" />
                        <Button Style="{StaticResource ActionButton}" Content="PDF" Margin="0,0,0,2"
                                Padding="12,6" HorizontalContentAlignment="Left"
                                PreviewMouseLeftButtonDown="OnExportPdfClick" />
                        <Button Style="{StaticResource ActionButton}" Content="Print"
                                Padding="12,6" HorizontalContentAlignment="Left"
                                PreviewMouseLeftButtonDown="OnExportPrintClick" />
                    </StackPanel>
                </Border>
            </Popup>

            <Border Grid.Row="3" Style="{StaticResource SoListSectionBorder}" Padding="1">
                <Grid>
                    <ContentPresenter x:Name="GridHost"
                                      Content="{Binding GridContent, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    <Border Panel.ZIndex="10" Style="{StaticResource ListBusyLoadingHost}"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                        <controls:ListLoadingOverlay Title="Loading report…" Subtitle="Please wait while data is retrieved" />
                    </Border>
                </Grid>
            </Border>

            <ContentPresenter Grid.Row="4" Margin="0,8,0,0"
                              Content="{Binding FooterContent, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        </Grid>
    </controls:TransactionEntryShell>
</UserControl>