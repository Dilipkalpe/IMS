<UserControl x:Class="IMS.Views.DueDayReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:IMS.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1200"
             VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
             Background="{DynamicResource ContentBackgroundBrush}">
    <UserControl.Resources>
        <Style x:Key="DueDayTotalRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource SoListRowStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsTotal}" Value="True">
                    <Setter Property="Background" Value="#f1f3f6" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <views:StandardReportView>
        <views:StandardReportView.FilterContent>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="As On Date" Style="{StaticResource SoListReportFieldLabel}" />
                    <DatePicker SelectedDate="{Binding AsOnDate, Mode=TwoWay}" Height="32" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="Type" Style="{StaticResource SoListReportFieldLabel}" />
                    <ComboBox ItemsSource="{Binding TypeOptions}" SelectedItem="{Binding SelectedType}"
                              Padding="8,6" FontSize="13" Style="{StaticResource FormCombo}" />
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                    <TextBlock Text="Party" Style="{StaticResource SoListReportFieldLabel}" />
                    <TextBox Text="{Binding PartyName, UpdateSourceTrigger=PropertyChanged}" Padding="8,6" FontSize="13" />
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Style="{StaticResource SoListReportShowButton}" Command="{Binding ShowCommand}" />
                </StackPanel>
            </Grid>
        </views:StandardReportView.FilterContent>

        <views:StandardReportView.GridContent>
            <DataGrid ItemsSource="{Binding Rows}"
                      Style="{StaticResource SoListOrdersGrid}"
                      ColumnHeaderStyle="{StaticResource SoListColumnHeader}"
                      RowStyle="{StaticResource DueDayTotalRowStyle}"
                      CellStyle="{StaticResource SoListDataGridCell}"
                      AlternationCount="2"
                      MinRowHeight="42"
                      ColumnHeaderHeight="44"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding SerialNo}" Width="52">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListCell}">
                                <Setter Property="HorizontalAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Type" Binding="{Binding PartyType}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Party" Binding="{Binding PartyName}" Width="*" MinWidth="160">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Doc No" Binding="{Binding DocNo}" Width="95">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Due Date" Binding="{Binding DueDate}" Width="95">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Due Days" Binding="{Binding DueDays}" Width="70">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListAmountCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Bucket" Binding="{Binding DueBucket}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Amount" Binding="{Binding BalanceDueDisplay}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListAmountCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </views:StandardReportView.GridContent>
    </views:StandardReportView>
</UserControl>
