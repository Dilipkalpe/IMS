<Window x:Class="IMS.Views.ProductBrowseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:IMS.Views"
        xmlns:conv="clr-namespace:IMS.Converters"
        Title="Browse products"
        Width="940" Height="580"
        MinWidth="720" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource TransactionPageBackgroundBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/IMS;component/Resources/AppResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding SelectionHelpText}"
                   TextWrapping="Wrap" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <RadioButton x:Name="SingleSelectModeRadio" Content="Single select" GroupName="SelectMode"
                         Margin="0,0,16,0" VerticalAlignment="Center"
                         Checked="SelectModeRadio_OnChecked" />
            <RadioButton x:Name="MultiSelectModeRadio" Content="Multi select" GroupName="SelectMode"
                         VerticalAlignment="Center"
                         Checked="SelectModeRadio_OnChecked" />
            <TextBlock Text="{Binding SelectedCount, StringFormat='({0} selected)'}" Margin="16,0,0,0"
                       VerticalAlignment="Center" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Visibility="{Binding IsMultiSelectMode, Converter={StaticResource BoolToVis}}" />
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MaxWidth="420" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource FormInput}" Height="32"
                     ToolTip="Type to search — results update automatically" />
            <Button Grid.Column="1" Content="Search" Margin="8,0,0,0" MinWidth="80" Height="32"
                    Style="{StaticResource SecondaryButton}" Command="{Binding SearchCommand}" />
            <Button Grid.Column="2" Content="All on page" Margin="8,0,0,0" MinWidth="88" Height="32"
                    Style="{StaticResource SecondaryButton}" Command="{Binding SelectAllOnPageCommand}"
                    Visibility="{Binding IsMultiSelectMode, Converter={StaticResource BoolToVis}}" />
            <Button Grid.Column="3" Content="Clear" Margin="8,0,0,0" MinWidth="64" Height="32"
                    Style="{StaticResource SecondaryButton}" Command="{Binding ClearSelectionCommand}"
                    Visibility="{Binding IsMultiSelectMode, Converter={StaticResource BoolToVis}}" />
        </Grid>

        <Border Grid.Row="3" BorderBrush="{StaticResource TransactionGridBorderBrush}"
                BorderThickness="1" Background="White">
            <DataGrid x:Name="ProductsGrid"
                      ItemsSource="{Binding Rows}"
                      SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      IsReadOnly="False"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      RowHeight="28"
                      FontSize="12"
                      MouseDoubleClick="ProductsGrid_OnMouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="✓" Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Visibility="{Binding DataContext.IsMultiSelectMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Sr." Binding="{Binding RowNumber}" Width="48" IsReadOnly="True" />
                    <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="120" IsReadOnly="True" />
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" MinWidth="200" IsReadOnly="True" />
                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120" IsReadOnly="True" />
                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="72" IsReadOnly="True" />
                    <DataGridTextColumn x:Name="RateColumn" Binding="{Binding Rate, StringFormat=N2}" Width="100" IsReadOnly="True" />
                    <DataGridTextColumn Header="Stock" Binding="{Binding StockQty, StringFormat=N2}" Width="80" IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <views:PaginationBar Grid.Row="4" DataContext="{Binding}" Margin="0,4,0,0" />

        <DockPanel Grid.Row="5" Margin="0,12,0,0" LastChildFill="True">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button MinWidth="120" Height="32" Margin="0,0,8,0"
                        Style="{StaticResource PrimaryButton}" Command="{Binding SelectCommand}"
                        Content="{Binding SelectButtonText}"
                        IsDefault="True" />
                <Button Content="Cancel" MinWidth="96" Height="32"
                        Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}"
                        IsCancel="True" />
            </StackPanel>
            <TextBlock VerticalAlignment="Center" Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource DangerBrush}" TextTrimming="CharacterEllipsis" />
        </DockPanel>
    </Grid>
</Window>
