<UserControl x:Class="IMS.Views.BillFormatDesignerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:IMS.Views.Controls"
             xmlns:converters="clr-namespace:IMS.Converters"
             xmlns:subvm="clr-namespace:IMS.ViewModels.SubPages"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="760" d:DesignWidth="1280"
             Background="#dce4ec">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <HierarchicalDataTemplate DataType="{x:Type subvm:BillFormatExplorerNodeViewModel}"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="0,1">
                <Button Style="{StaticResource ActionButton}" Content="+" Padding="5,0" Margin="0,0,4,0"
                        FontSize="11" ToolTip="Add to layout"
                        Visibility="{Binding CanInsert, Converter={StaticResource BoolToVisibilityConverter}}"
                        Command="{Binding InsertCommand}" CommandParameter="{Binding}" />
                <TextBlock Text="{Binding Title}" FontSize="12" VerticalAlignment="Center" />
            </StackPanel>
        </HierarchicalDataTemplate>

        <Style x:Key="CrystalBandHeader" TargetType="Border">
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="1,1,1,0" />
        </Style>

        <Style x:Key="CrystalFieldBox" TargetType="Border">
            <Setter Property="Background" Value="#ffffff" />
            <Setter Property="BorderBrush" Value="#2563eb" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </UserControl.Resources>

    <controls:TransactionEntryShell Title="{Binding PageTitle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Crystal-style menu / toolbar -->
            <Border Grid.Row="0" Background="#2c3e50" Padding="6,4">
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                        <Button Style="{StaticResource ActionButton}" Content="Print Preview" Margin="0,0,6,0"
                                Padding="10,4" Command="{Binding PreviewCommand}" />
                        <Button Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}" Margin="0,0,6,0" Padding="10,4">
                            <TextBlock Text="Save" Foreground="White" FontWeight="SemiBold" FontSize="11" />
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}" Padding="10,4" Margin="0,0,12,0">
                            <TextBlock Text="Close" FontSize="11" />
                        </Button>
                        <TextBlock Text="Paper:" Foreground="#e2e8f0" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="11" />
                        <ComboBox Width="140" Style="{StaticResource SubPageFormCombo}"
                                  ItemsSource="{Binding PaperPresets}"
                                  SelectedValuePath="Key" DisplayMemberPath="Label"
                                  SelectedValue="{Binding SelectedPaperPresetKey}" />
                        <TextBlock Text="Zoom:" Foreground="#e2e8f0" VerticalAlignment="Center" Margin="12,0,6,0" FontSize="11" />
                        <ComboBox Width="72" Style="{StaticResource SubPageFormCombo}"
                                  ItemsSource="{Binding ZoomOptions}"
                                  SelectedItem="{Binding SelectedZoom}" />
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Right" Text="{Binding FormatSummary}" Foreground="#cbd5e1"
                               FontSize="11" VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <TextBlock Grid.Row="1" Margin="8,4" FontSize="11" Foreground="#475569"
                       Text="{Binding FormatContextLine}" />

            <!-- Main designer: Field Explorer | Design | Properties -->
            <Grid Grid.Row="2" Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="*" MinWidth="400" />
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="272" />
                </Grid.ColumnDefinitions>

                <!-- Field Explorer (left) -->
                <Border Grid.Column="0" Background="#f1f5f9" BorderBrush="#94a3b8" BorderThickness="1">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#475569" Padding="8,5">
                            <TextBlock Text="Field Explorer" Foreground="White" FontWeight="SemiBold" FontSize="12" />
                        </Border>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6">
                            <StackPanel>
                                <TreeView x:Name="ExplorerTree" ItemsSource="{Binding ExplorerRoots}"
                                          BorderThickness="0" Background="Transparent"
                                          Margin="0,0,0,8"
                                          MouseDoubleClick="ExplorerTree_OnMouseDoubleClick" />
                                <Button Style="{StaticResource ActionButton}" Content="Add item details to layout"
                                        Command="{Binding AddItemDetailsCommand}" Margin="0,0,0,8"
                                        Padding="8,4" FontSize="11" HorizontalAlignment="Stretch" />
                                <TextBlock Text="Detail columns — loaded from Settings → Manage columns (gridcolumnglobaldefaults, same module as transaction type)"
                                           FontSize="10" Foreground="#64748b" TextWrapping="Wrap" Margin="0,0,0,6" />
                                <TextBlock Text="Detail columns (check to show on print)" FontWeight="SemiBold" FontSize="11" Margin="0,4,0,4" />
                                <TextBlock Text="No columns loaded — open format again or click Add item details."
                                           FontSize="10" Foreground="#64748b" TextWrapping="Wrap"
                                           Margin="0,0,0,6">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasItemColumns}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ItemsControl ItemsSource="{Binding ItemColumns}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Header}" IsChecked="{Binding Visible, Mode=TwoWay}"
                                                      FontSize="11" Margin="0,2"
                                                      Checked="OnColumnChanged" Unchecked="OnColumnChanged" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Bill options" FontWeight="SemiBold" FontSize="11" Margin="0,10,0,4" />
                                <CheckBox Content="Company logo" IsChecked="{Binding Visibility.ShowLogo}" FontSize="11" Margin="0,2" />
                                <CheckBox Content="GST details" IsChecked="{Binding Visibility.ShowGst}" FontSize="11" Margin="0,2" />
                                <CheckBox Content="Tax breakup" IsChecked="{Binding Visibility.ShowTaxBreakup}" FontSize="11" Margin="0,2" />
                                <CheckBox Content="Amount in words" IsChecked="{Binding Visibility.ShowAmountInWords}" FontSize="11" Margin="0,2" />
                                <CheckBox Content="Print preview on save" IsChecked="{Binding PrintSettings.PrintPreview}" FontSize="11" Margin="0,2" />
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#94a3b8" />

                <!-- Design surface (center) -->
                <Border Grid.Column="2" Background="#64748b" BorderBrush="#334155" BorderThickness="1">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#1e293b" Padding="8,5">
                            <TextBlock Text="Design — drag fields to position; click to select" Foreground="#e2e8f0" FontSize="12" />
                        </Border>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                      Background="#94a3b8" Padding="16">
                            <Border Background="White"
                                    Width="{Binding DesignPageWidth}"
                                    Height="{Binding DesignPageHeight}"
                                    BorderBrush="#0f172a" BorderThickness="1"
                                    HorizontalAlignment="Left" VerticalAlignment="Top">
                                <ItemsControl ItemsSource="{Binding Bands}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type subvm:BillFormatBandViewModel}">
                                            <StackPanel>
                                                <Border Style="{StaticResource CrystalBandHeader}"
                                                        Background="{Binding HeaderColor}">
                                                    <TextBlock Text="{Binding Title}" Foreground="White"
                                                               FontSize="11" FontWeight="SemiBold" />
                                                </Border>
                                                <Border Background="#fafafa" BorderBrush="#cbd5e1"
                                                        BorderThickness="1,0,1,1"
                                                        MinHeight="{Binding BandHeight}">
                                                    <Canvas x:Name="BandCanvas" Background="Transparent"
                                                            Loaded="BandCanvas_OnLoaded"
                                                            SizeChanged="BandCanvas_OnSizeChanged"
                                                            Tag="{Binding Key}">
                                                        <ItemsControl ItemsSource="{Binding Sections}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <Canvas />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate DataType="{x:Type subvm:DesignerSectionViewModel}">
                                                                    <Border Style="{StaticResource CrystalFieldBox}"
                                                                            MinWidth="72" MinHeight="24"
                                                                            MouseLeftButtonDown="SectionBlock_OnMouseDown"
                                                                            MouseMove="SectionBlock_OnMouseMove"
                                                                            MouseLeftButtonUp="SectionBlock_OnMouseLeftButtonUp"
                                                                            Tag="{Binding}">
                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" FontSize="11" />
                                                                            <TextBlock Text="{Binding Text}" FontSize="9" Foreground="#64748b"
                                                                                       TextTrimming="CharacterEllipsis" MaxWidth="200" />
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Canvas>
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch" Background="#94a3b8" />

                <!-- Properties (right) -->
                <Border Grid.Column="4" Background="#f8fafc" BorderBrush="#94a3b8" BorderThickness="1">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#475569" Padding="8,5">
                            <TextBlock Text="Properties" Foreground="White" FontWeight="SemiBold" FontSize="12" />
                        </Border>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                            <StackPanel DataContext="{Binding SelectedSection}"
                                        IsEnabled="{Binding DataContext.HasSelectedSection, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                <TextBlock Text="Object" Style="{StaticResource SubPageFormLabel}" />
                                <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource SubPageFormInput}" Margin="0,0,0,8" />

                                <TextBlock Text="Text / formula" Style="{StaticResource SubPageFormLabel}" />
                                <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource SubPageFormMultiline}" Height="48" Margin="0,0,0,8"
                                         LostFocus="OnSectionLostFocus" />

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Left %" Style="{StaticResource SubPageFormLabel}" />
                                    <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding X, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SubPageFormInput}" LostFocus="OnSectionLostFocus" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Top %" Style="{StaticResource SubPageFormLabel}" />
                                    <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding Y, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SubPageFormInput}" LostFocus="OnSectionLostFocus" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Width %" Style="{StaticResource SubPageFormLabel}" Margin="0,6,0,0" />
                                    <TextBox Grid.Row="3" Grid.Column="0" Text="{Binding Width, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SubPageFormInput}" LostFocus="OnSectionLostFocus" />
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Height %" Style="{StaticResource SubPageFormLabel}" Margin="0,6,0,0" />
                                    <TextBox Grid.Row="3" Grid.Column="2" Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SubPageFormInput}" LostFocus="OnSectionLostFocus" />
                                </Grid>

                                <TextBlock Text="Font size (pt)" Style="{StaticResource SubPageFormLabel}" />
                                <TextBox Text="{Binding FontSizePt, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource SubPageFormInput}" Margin="0,0,0,8"
                                         LostFocus="OnSectionLostFocus" />

                                <TextBlock Text="Alignment" Style="{StaticResource SubPageFormLabel}" />
                                <ComboBox Style="{StaticResource SubPageFormCombo}"
                                          ItemsSource="{Binding DataContext.AlignOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedItem="{Binding Align, Mode=TwoWay}" Margin="0,0,0,8"
                                          SelectionChanged="OnSectionChanged" />

                                <CheckBox Content="Print object (visible)" IsChecked="{Binding Visible, Mode=TwoWay}"
                                          Margin="0,0,0,8" Checked="OnSectionChanged" Unchecked="OnSectionChanged" />
                                <CheckBox Content="Show border" IsChecked="{Binding ShowBorder, Mode=TwoWay}"
                                          Checked="OnSectionChanged" Unchecked="OnSectionChanged" />

                                <Button Style="{StaticResource ActionButton}" Content="Remove object" Margin="0,12,0,0"
                                        Command="{Binding DataContext.RemoveSectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>

            <Border Grid.Row="3" Background="#e2e8f0" Padding="8,4" Margin="4,4,4,0">
                <DockPanel>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="#334155" />
                    <TextBlock DockPanel.Dock="Right" Text="{Binding PageSizeLabel}" FontSize="11" Foreground="#64748b" />
                </DockPanel>
            </Border>
        </Grid>
    </controls:TransactionEntryShell>
</UserControl>
