<UserControl x:Class="IMS.Views.SalesPurchaseConfigurationPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:IMS.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisInvert" Invert="True" />
    </UserControl.Resources>
    <StackPanel>
        <TextBlock Text="Sales / Purchase configuration" Style="{StaticResource SectionHeader}" />
        <TextBlock Text="Choose where the sales invoice line rate comes from when you add a product. Saved invoices keep their existing rates until you add or change lines."
                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,12" />

        <TextBlock Text="Only administrators can change this setting."
                   Visibility="{Binding CanManageSettings, Converter={StaticResource BoolToVisInvert}}"
                   Foreground="#C62828" FontSize="12" Margin="0,0,0,12" TextWrapping="Wrap" />

        <StackPanel IsEnabled="{Binding CanManageSettings}">
            <TextBlock Text="Sales rate source" Style="{StaticResource FormLabel}" Margin="0,0,0,8" />

            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6"
                    Padding="10,8" Margin="0,0,0,8" Background="{DynamicResource CardBrush}">
                <RadioButton GroupName="SalesRateSource"
                             IsChecked="{Binding UseProductMasterSalesRate, Mode=TwoWay}"
                             VerticalAlignment="Top">
                    <StackPanel Margin="4,0,0,0">
                        <TextBlock Text="Product Master" FontWeight="SemiBold" FontSize="13" />
                        <TextBlock Text="Use the sale price from the product master when adding lines to a sales invoice."
                                   FontSize="12" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </RadioButton>
            </Border>

            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6"
                    Padding="10,8" Margin="0,0,0,12" Background="{DynamicResource CardBrush}">
                <RadioButton GroupName="SalesRateSource"
                             IsChecked="{Binding UsePurchaseInvoiceSalesRate, Mode=TwoWay}"
                             VerticalAlignment="Top">
                    <StackPanel Margin="4,0,0,0">
                        <TextBlock Text="Purchase Invoice" FontWeight="SemiBold" FontSize="13" />
                        <TextBlock Text="Use the sale rate from the most recent purchase invoice line for that product."
                                   FontSize="12" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </RadioButton>
            </Border>

            <Border Style="{StaticResource HighlightPanel}" Margin="0,0,0,8">
                <TextBlock Text="{Binding ActiveSourceSummary}" FontWeight="SemiBold" FontSize="12"
                           Foreground="{DynamicResource AccentBrush}" TextWrapping="Wrap" />
            </Border>

            <TextBlock Text="{Binding StatusMessage}" FontSize="12" TextWrapping="Wrap"
                       Foreground="{DynamicResource AccentBrush}" />
        </StackPanel>
    </StackPanel>
</UserControl>
