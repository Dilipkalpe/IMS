<UserControl x:Class="IMS.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:IMS.Converters"
             xmlns:views="clr-namespace:IMS.Views"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24,20,24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource PageIconHost}" Margin="0,0,14,0">
                    <TextBlock Style="{StaticResource IconText}" FontSize="22"
                               Foreground="{DynamicResource AccentBrush}" Text="{Binding IconGlyph}" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource PageTitle}" Text="{Binding PageTitle}" />
                    <TextBlock Style="{StaticResource PageSubtitle}" Text="{Binding PageDescription}" />
                </StackPanel>
            </Grid>

            <!-- API / IIS connection -->
            <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,12" Padding="20">
                <views:ApiConnectionSettingsPanel DataContext="{Binding ApiConnection}" />
            </Border>

            <!-- Sales order print format -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,12" Padding="20">
                <StackPanel>
                    <TextBlock Text="Sales order bill — print format" Style="{StaticResource SectionHeader}" />
                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,16">
                        <Run Text="Sales bills use " /><Run FontWeight="SemiBold" Text="Bill Format Master" /><Run Text=" (sections, columns, paper, preview). Settings below apply only when no bill format is configured in the master." />
                    </TextBlock>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Paper size" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding PrintFormats}"
                                  SelectedItem="{Binding SelectedPrintFormat, Mode=TwoWay}"
                                  Style="{StaticResource FormCombo}"
                                  MinWidth="280">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>

                    <TextBlock Text="{Binding SelectedPrintFormat.Description}"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" Margin="140,0,0,12" />

                    <StackPanel Visibility="{Binding IsCustomFormat, Converter={StaticResource BoolToVis}}" Margin="0,0,0,12">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Custom size" Style="{StaticResource FormLabel}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding CustomWidthMm, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormInput}" />
                            <TextBlock Grid.Column="2" Text="mm wide" VerticalAlignment="Center" Margin="8,0,16,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                            <TextBox Grid.Column="3" Text="{Binding CustomHeightMm, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormInput}" />
                            <TextBlock Grid.Column="4" Text="mm high" VerticalAlignment="Center" Margin="8,0,0,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                        </Grid>
                        <TextBlock Text="Example: 80 × 200 mm for a narrow receipt, or 210 × 99 mm for a half-page bill."
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" TextWrapping="Wrap" Margin="140,0,0,0" />
                    </StackPanel>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Page margin" Style="{StaticResource FormLabel}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding MarginMm, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormInput}" />
                        <TextBlock Grid.Column="2" Text="mm (all sides)" VerticalAlignment="Center" Margin="8,0,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                    </Grid>

                    <Border Style="{StaticResource HighlightPanel}" Margin="0,4,0,0">
                        <StackPanel>
                            <TextBlock Text="Active print layout" FontWeight="SemiBold" FontSize="12"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding PrintFormatSummary}" Margin="0,6,0,0"
                                       Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="Saved automatically. Sales counter print actions use this format immediately."
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Grid column visibility -->
            <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,0,0,12" Padding="20"
                    DataContext="{Binding GridColumns}">
                <StackPanel>
                    <TextBlock Text="Manage columns" Style="{StaticResource SectionHeader}" />
                    <TextBlock Text="Show or hide line-item grid columns for sales and purchase documents. Changes apply immediately and are saved per user. Mandatory columns cannot be hidden."
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,12" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Module" Style="{StaticResource FormLabel}" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding ModuleChoices}"
                                  SelectedItem="{Binding SelectedModule, Mode=TwoWay}"
                                  DisplayMemberPath="Title"
                                  Style="{StaticResource FormCombo}"
                                  MinWidth="280" />
                    </Grid>

                    <ItemsControl ItemsSource="{Binding ColumnOptions}" Margin="0,0,0,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Header}"
                                          IsChecked="{Binding IsVisible, Mode=TwoWay}"
                                          Margin="0,0,0,6" FontSize="13">
                                    <CheckBox.Style>
                                        <Style TargetType="CheckBox">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMandatory}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False" />
                                                    <Setter Property="ToolTip" Value="This column is required and cannot be hidden." />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </CheckBox.Style>
                                </CheckBox>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Reset to default" Command="{Binding ResetGridColumnsCommand}"
                                Style="{StaticResource SecondaryButton}" Padding="14,8" Margin="0,0,10,0" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                                Visibility="{Binding CanManageGlobalDefaults, Converter={StaticResource BoolToVis}}">
                        <Button Content="Save as organization default" Command="{Binding SaveAsGlobalDefaultCommand}"
                                Style="{StaticResource SecondaryButton}" Padding="14,8" Margin="0,0,10,0" />
                        <Button Content="Reset organization default" Command="{Binding ResetGlobalDefaultCommand}"
                                Style="{StaticResource SecondaryButton}" Padding="14,8" />
                    </StackPanel>

                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" TextWrapping="Wrap"
                               Foreground="{DynamicResource AccentBrush}" />
                </StackPanel>
            </Border>

            <!-- Appearance -->
            <Border Grid.Row="4" Style="{StaticResource Card}" Margin="0,0,0,12" Padding="20">
                <StackPanel>
                    <TextBlock Text="Appearance" Style="{StaticResource SectionHeader}" />
                    <TextBlock Text="Choose a color theme for the application shell, pages, and KPI accents."
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,16" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Color theme" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding Themes}"
                                  SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName"
                                  Style="{StaticResource FormCombo}"
                                  MinWidth="280" />
                    </Grid>

                    <Border Style="{StaticResource HighlightPanel}" Margin="0,4,0,0">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedTheme.Description}" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" />
                            <TextBlock Text="{Binding ActiveThemeSummary}" Margin="0,8,0,0"
                                       Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" FontSize="12" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Database backup on exit -->
            <Border Grid.Row="5" Style="{StaticResource Card}" Margin="0,0,0,12" Padding="20">
                <StackPanel>
                    <TextBlock Text="Database backup on exit" Style="{StaticResource SectionHeader}" />
                    <TextBlock Text="When you close the application, IMS can create a MongoDB archive backup (mongodump) before exiting. Backups use the file name DatabaseBackup_YYYYMMDD_HHMMSS.bak."
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,16" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Backup folder" Style="{StaticResource FormLabel}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding DatabaseBackupFolder, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormInput}" IsReadOnly="True" />
                        <Button Grid.Column="2" Content="Browse…" Command="{Binding BrowseBackupFolderCommand}"
                                Style="{StaticResource SecondaryButton}" Padding="14,8" Margin="12,0,0,0" />
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="On close" Style="{StaticResource FormLabel}" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding ExitBackupPreferenceOptions}"
                                  SelectedItem="{Binding SelectedExitBackupPreference, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName"
                                  Style="{StaticResource FormCombo}"
                                  MinWidth="280" />
                    </Grid>

                    <TextBlock Text="{Binding SelectedExitBackupPreference.Description}"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" Margin="140,0,0,12" />

                    <Border Style="{StaticResource HighlightPanel}" Margin="0,4,0,0">
                        <StackPanel>
                            <TextBlock Text="Resolved backup path" FontWeight="SemiBold" FontSize="12"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding ResolvedBackupFolder}" Margin="0,6,0,0"
                                       Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
                            <TextBlock Text="The folder is created automatically if it does not exist. Backup activity is also logged locally under %LocalAppData%\IMS\backup-logs.jsonl."
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{Binding BackupSettingsStatusMessage}" FontSize="12" TextWrapping="Wrap"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,10,0,0" />
                </StackPanel>
            </Border>

            <!-- Sales / Purchase configuration -->
            <Border Grid.Row="6" Style="{StaticResource Card}" Margin="0,0,0,12" Padding="20">
                <views:SalesPurchaseConfigurationPanel DataContext="{Binding SalesPurchase}" />
            </Border>

            <!-- Communication settings -->
            <Border Grid.Row="7" Style="{StaticResource Card}" Margin="0,0,0,12" Padding="20">
                <views:CommunicationSettingsPanel DataContext="{Binding Communication}" />
            </Border>

            <!-- Software license (admin) -->
            <Border Grid.Row="8" Style="{StaticResource Card}" Margin="0,0,0,12" Padding="20"
                    Visibility="{Binding CanManageLicense, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="Software license" Style="{StaticResource SectionHeader}" />
                    <TextBlock Text="Choose Trial (set valid days, extend when needed) or Permanent (no expiry). Only administrators can change the license."
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,12" />

                    <TextBlock Text="{Binding LicenseStatusText}" FontSize="12" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="License type" Style="{StaticResource FormLabel}" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding LicenseTypeOptions}"
                                  SelectedItem="{Binding SelectedLicenseType, Mode=TwoWay}"
                                  Style="{StaticResource FormCombo}"
                                  MinWidth="220">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>

                    <TextBlock Text="{Binding SelectedLicenseType.Description}"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" Margin="140,0,0,12" />

                    <Grid Margin="0,0,0,12"
                          Visibility="{Binding IsTrialLicenseSelected, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Valid days" Style="{StaticResource FormLabel}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding SelectedLicenseValidDays, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Height="36" Padding="10,6" VerticalContentAlignment="Center" Margin="0,0,10,0" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                            <Button Content="15" Command="{Binding SelectTrialDaysCommand}" CommandParameter="15"
                                    Style="{StaticResource SecondaryButton}" Padding="10,6" Margin="0,0,6,0" />
                            <Button Content="30" Command="{Binding SelectTrialDaysCommand}" CommandParameter="30"
                                    Style="{StaticResource SecondaryButton}" Padding="10,6" Margin="0,0,6,0" />
                            <Button Content="45" Command="{Binding SelectTrialDaysCommand}" CommandParameter="45"
                                    Style="{StaticResource SecondaryButton}" Padding="10,6" />
                        </StackPanel>
                        <Button Grid.Column="3" Content="Apply license"
                                Command="{Binding RenewLicenseCommand}"
                                Style="{StaticResource PrimaryButton}" Padding="14,8" />
                    </Grid>

                    <Grid Margin="0,0,0,12"
                          Visibility="{Binding IsPermanentLicenseSelected, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Permanent" Style="{StaticResource FormLabel}" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="Apply permanent license"
                                Command="{Binding RenewLicenseCommand}"
                                Style="{StaticResource PrimaryButton}" Padding="14,8" HorizontalAlignment="Left" />
                    </Grid>

                    <StackPanel Visibility="{Binding IsTrialLicenseSelected, Converter={StaticResource BoolToVis}}">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Extend by (days)" Style="{StaticResource FormLabel}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding LicenseExtensionDays, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Height="36" Padding="10,6" VerticalContentAlignment="Center" Margin="0,0,10,0" />
                        <TextBox Grid.Column="2" Text="{Binding LicenseExtensionNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Height="36" Padding="10,6" VerticalContentAlignment="Center" Margin="0,0,10,0"
                                 ToolTip="Optional note for this extension" />
                        <Button Grid.Column="3" Content="Extend license"
                                Command="{Binding ExtendLicenseCommand}"
                                Style="{StaticResource SecondaryButton}" Padding="14,8" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="140,0,0,0">
                        <Button Content="+15 days" Command="{Binding ExtendLicenseQuickCommand}" CommandParameter="15"
                                Style="{StaticResource SecondaryButton}" Padding="12,6" Margin="0,0,8,0" />
                        <Button Content="+30 days" Command="{Binding ExtendLicenseQuickCommand}" CommandParameter="30"
                                Style="{StaticResource SecondaryButton}" Padding="12,6" Margin="0,0,8,0" />
                        <Button Content="+45 days" Command="{Binding ExtendLicenseQuickCommand}" CommandParameter="45"
                                Style="{StaticResource SecondaryButton}" Padding="12,6" />
                    </StackPanel>
                    </StackPanel>

                    <TextBlock Text="{Binding LicenseActionMessage}" FontSize="12" TextWrapping="Wrap"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,10,0,0" />
                </StackPanel>
            </Border>

            <!-- Edit/delete confirmation password (admin) -->
            <Border Grid.Row="9" Style="{StaticResource Card}" Margin="0,0,0,12" Padding="20"
                    Visibility="{Binding CanManageEditDeletePassword, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="Edit/delete confirmation password" Style="{StaticResource SectionHeader}" />
                    <TextBlock Text="When enabled, users must enter the confirmation password before any edit or delete on any page. When disabled, no password window is shown and actions proceed immediately. The password is stored hashed in MongoDB."
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,12" />

                    <CheckBox Content="Require confirmation password for all edit and delete operations"
                              IsChecked="{Binding RequireEditDeleteConfirmation, Mode=TwoWay}"
                              FontSize="13" Margin="0,0,0,12" />

                    <TextBlock Text="{Binding EditDeletePasswordStatus}" FontSize="12" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16" />

                    <StackPanel IsEnabled="{Binding RequireEditDeleteConfirmation}">

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="New password" Style="{StaticResource FormLabel}" VerticalAlignment="Center" />
                        <PasswordBox x:Name="NewEditDeletePasswordBox" Grid.Column="1" Height="36" Padding="10,6"
                                     PasswordChanged="NewEditDeletePasswordBox_OnPasswordChanged" />
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Confirm password" Style="{StaticResource FormLabel}" VerticalAlignment="Center" />
                        <PasswordBox x:Name="ConfirmEditDeletePasswordBox" Grid.Column="1" Height="36" Padding="10,6"
                                     PasswordChanged="ConfirmEditDeletePasswordBox_OnPasswordChanged" />
                    </Grid>

                    <Button Content="Update confirmation password" Command="{Binding UpdateEditDeletePasswordCommand}"
                            Style="{StaticResource PrimaryButton}" Padding="14,8" HorizontalAlignment="Left" />
                    </StackPanel>

                    <TextBlock Text="{Binding SecurityStatusMessage}" FontSize="12" TextWrapping="Wrap"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,10,0,0" />
                </StackPanel>
            </Border>

            <!-- Delete all database data -->
            <Border Grid.Row="10" Style="{StaticResource Card}" Margin="0,0,0,12" Padding="20"
                    BorderBrush="#C62828" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Delete all data" Style="{StaticResource SectionHeader}"
                               Foreground="#C62828" />
                    <TextBlock Text="Permanently remove every business record from the MongoDB database used by this IMS installation. Use only for a full reset or before go-live."
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,12" />

                    <TextBlock Text="{Binding DataSummaryText}" FontSize="12" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Refresh counts" Command="{Binding RefreshDataSummaryCommand}"
                                Style="{StaticResource SecondaryButton}" Padding="14,8" Margin="0,0,10,0" />
                        <Button Content="Delete all database data…" Command="{Binding DeleteAllDataCommand}"
                                Padding="14,8" Background="#C62828" Foreground="White" BorderBrush="#B71C1C" />
                    </StackPanel>

                    <TextBlock Text="{Binding DataStatusMessage}" FontSize="12" TextWrapping="Wrap"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,4,0,0" />
                    <TextBlock Text="After delete, run npm run seed in the api folder to load sample data again."
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Row="11" Style="{StaticResource Card}" Padding="20" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Theme previews" Style="{StaticResource SectionHeader}" />
                    <ItemsControl ItemsSource="{Binding Themes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="12" Margin="0,0,0,8"
                                        Background="{DynamicResource CardBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="40" Height="40" CornerRadius="8" Margin="0,0,12,0"
                                                Background="{Binding PreviewColor, Converter={StaticResource HexToBrushConverter}}" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                            <TextBlock Text="{Binding Description}" FontSize="12" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="Your selection is saved automatically and restored on next launch."
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
