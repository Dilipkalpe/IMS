<UserControl x:Class="IMS.Views.PaginationBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="48" d:DesignWidth="600">
    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,8,0,0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{Binding PageInfo}" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                <TextBlock Text="Rows per page" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                <ComboBox ItemsSource="{Binding PageSizeOptions}"
                          SelectedItem="{Binding SelectedPageSize, Mode=TwoWay}"
                          MinWidth="72" VerticalAlignment="Center"
                          Style="{StaticResource FormCombo}" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource PagingButton}" Command="{Binding FirstPageCommand}" ToolTip="First page">
                    <TextBlock Style="{StaticResource IconText}" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" Text="&#xE892;" />
                </Button>
                <Button Style="{StaticResource PagingButton}" Command="{Binding PreviousPageCommand}" ToolTip="Previous">
                    <TextBlock Style="{StaticResource IconText}" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" Text="&#xE76B;" />
                </Button>
                <Border Background="{DynamicResource PanelMutedBrush}" CornerRadius="6" Padding="12,6" Margin="4,0">
                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13">
                        <Run Text="{Binding CurrentPage, Mode=OneWay}" />
                        <Run Text=" / " />
                        <Run Text="{Binding TotalPages, Mode=OneWay}" />
                    </TextBlock>
                </Border>
                <Button Style="{StaticResource PagingButton}" Command="{Binding NextPageCommand}" ToolTip="Next">
                    <TextBlock Style="{StaticResource IconText}" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" Text="&#xE76C;" />
                </Button>
                <Button Style="{StaticResource PagingButton}" Command="{Binding LastPageCommand}" ToolTip="Last page">
                    <TextBlock Style="{StaticResource IconText}" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" Text="&#xE893;" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
