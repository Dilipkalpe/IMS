<UserControl x:Class="IMS.Views.ClosingStockReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:IMS.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1200"
             VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
             Background="{DynamicResource ContentBackgroundBrush}">
    <views:StandardReportView>
        <views:StandardReportView.FilterContent>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,10">
                    <TextBlock Text="Product Code" Style="{StaticResource SoListReportFieldLabel}" />
                    <TextBox Text="{Binding FilterProductCode, UpdateSourceTrigger=PropertyChanged}"
                             Padding="8,6" FontSize="13" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,12,10">
                    <TextBlock Text="Main Name" Style="{StaticResource SoListReportFieldLabel}" />
                    <ComboBox ItemsSource="{Binding MainGroupOptions}"
                              SelectedItem="{Binding FilterMainName}"
                              Padding="8,6" FontSize="13" Style="{StaticResource FormCombo}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,10">
                    <TextBlock Text="Product Name" Style="{StaticResource SoListReportFieldLabel}" />
                    <TextBox Text="{Binding FilterProductName, UpdateSourceTrigger=PropertyChanged}"
                             Padding="8,6" FontSize="13" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,12,10">
                    <TextBlock Text="Item Description" Style="{StaticResource SoListReportFieldLabel}" />
                    <TextBox Text="{Binding FilterItemDescription, UpdateSourceTrigger=PropertyChanged}"
                             Padding="8,6" FontSize="13" />
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="Product Type" Style="{StaticResource SoListReportFieldLabel}" />
                    <ComboBox ItemsSource="{Binding ProductTypeOptions}"
                              SelectedItem="{Binding FilterProductType}"
                              Padding="8,6" FontSize="13" Style="{StaticResource FormCombo}" />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="Godown" Style="{StaticResource SoListReportFieldLabel}" />
                    <ComboBox ItemsSource="{Binding GodownOptions}"
                              SelectedItem="{Binding FilterGodown}"
                              Padding="8,6" FontSize="13" Style="{StaticResource FormCombo}" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,10">
                    <TextBlock Text="Date From" Style="{StaticResource SoListReportFieldLabel}" />
                    <DatePicker SelectedDate="{Binding DateFrom, Mode=TwoWay}" Height="32" MinWidth="160" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,10">
                    <TextBlock Text="Date To" Style="{StaticResource SoListReportFieldLabel}" />
                    <DatePicker SelectedDate="{Binding DateTo, Mode=TwoWay}" Height="32" MinWidth="160" />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,0">
                    <TextBlock Text="Batch No" Style="{StaticResource SoListReportFieldLabel}" />
                    <TextBox Text="{Binding FilterBatchNo, UpdateSourceTrigger=PropertyChanged}"
                             Padding="8,6" FontSize="13" MinWidth="160" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="3"
                            Orientation="Horizontal" VerticalAlignment="Bottom"
                            Margin="12,0,0,0">
                    <Button Style="{StaticResource SoListReportShowButton}" Command="{Binding ShowCommand}" Margin="0,0,8,0" />
                    <Button Style="{StaticResource SoListReportPrintButton}" Command="{Binding PrintCommand}" />
                </StackPanel>
            </Grid>
        </views:StandardReportView.FilterContent>

        <views:StandardReportView.GridContent>
            <DataGrid ItemsSource="{Binding Rows}"
                      Style="{StaticResource SoListOrdersGrid}"
                      ColumnHeaderStyle="{StaticResource SoListColumnHeader}"
                      CellStyle="{StaticResource SoListDataGridCell}"
                      AlternationCount="2"
                      MinRowHeight="42"
                      ColumnHeaderHeight="44"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource SoListRowStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ProductName}" Value="Total :">
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Background" Value="#f1f3f6" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding SerialNo}" Width="52">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListCell}">
                                <Setter Property="HorizontalAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Product_ID" Binding="{Binding ProductId}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Product_Name" Binding="{Binding ProductName}" Width="*" MinWidth="180">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Op_Stock" Binding="{Binding OpStockDisplay}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListAmountCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Inward" Binding="{Binding InwardDisplay}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListAmountCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Outward" Binding="{Binding OutwardDisplay}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListAmountCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Cl_Stock" Binding="{Binding ClosingStockDisplay}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListAmountCell}">
                                <Setter Property="FontWeight" Value="Bold" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Avg_Rate" Binding="{Binding AvgRateDisplay}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListAmountCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Valuation" Binding="{Binding ValuationDisplay}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListAmountCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="ReOrderLevel" Binding="{Binding ReorderLevelDisplay}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListAmountCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </views:StandardReportView.GridContent>
    </views:StandardReportView>
</UserControl>
