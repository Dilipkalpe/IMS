<UserControl x:Class="IMS.Views.ReceiptVoucherEntryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:IMS.Views.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000"
             VerticalAlignment="Stretch"
             Background="{StaticResource TransactionPageBackgroundBrush}">
    <controls:TransactionEntryShell Title="{Binding PageTitle}">
        <controls:TransactionEntryShell.TitleRightHeader>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Voucher type" Style="{StaticResource TransactionInlineFieldLabel}" Margin="0,0,8,0" />
                <Border Style="{StaticResource MockBadge}" Padding="10,4" MinWidth="88">
                    <TextBlock Text="{Binding VoucherTypeLabel}" FontSize="12" FontWeight="Bold"
                               Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center" />
                </Border>
            </StackPanel>
        </controls:TransactionEntryShell.TitleRightHeader>

        <Grid Margin="0" VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{Binding PageDescription}" Style="{StaticResource PageSubtitle}" Margin="0,0,0,10" />

            <Border Grid.Row="1" Style="{StaticResource TransactionSectionBorder}" Padding="12,10" VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock Text="Voucher details" Style="{StaticResource SubPageSectionHeader}" />
                            <UniformGrid Columns="3" Margin="0,0,0,6">
                                <StackPanel Style="{StaticResource SubPageFieldCell}">
                                    <TextBlock Text="Voucher No *" Style="{StaticResource SubPageFormLabel}" />
                                    <TextBox Text="{Binding VoucherNo, UpdateSourceTrigger=PropertyChanged}"
                                             IsReadOnly="{Binding IsEdit}"
                                             Style="{StaticResource SubPageFormInput}" />
                                </StackPanel>
                                <StackPanel Style="{StaticResource SubPageFieldCell}">
                                    <TextBlock Text="Ref. No" Style="{StaticResource SubPageFormLabel}" />
                                    <TextBox Text="{Binding RefNo, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SubPageFormInput}" />
                                </StackPanel>
                                <StackPanel Style="{StaticResource SubPageFieldCell}">
                                    <TextBlock Text="Date *" Style="{StaticResource SubPageFormLabel}" />
                                    <DatePicker SelectedDate="{Binding VoucherDate, Mode=TwoWay}" Height="28" />
                                </StackPanel>
                            </UniformGrid>

                            <TextBlock Text="Receipt details" Style="{StaticResource SubPageSectionHeader}" />
                            <UniformGrid Columns="3" Margin="0,0,0,6">
                                <StackPanel Style="{StaticResource SubPageFieldCell}">
                                    <TextBlock Text="Cash / Bank *" Style="{StaticResource SubPageFormLabel}" />
                                    <ComboBox ItemsSource="{Binding CashBankOptions}"
                                              SelectedItem="{Binding CashBank, Mode=TwoWay}"
                                              Style="{StaticResource SubPageFormCombo}" />
                                </StackPanel>
                                <StackPanel Style="{StaticResource SubPageFieldCell}">
                                    <TextBlock Text="Amount *" Style="{StaticResource SubPageFormLabel}" />
                                    <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SubPageFormInput}" />
                                </StackPanel>
                                <StackPanel Style="{StaticResource SubPageFieldCell}" />
                            </UniformGrid>

                            <TextBlock Text="Account" Style="{StaticResource SubPageSectionHeader}" />
                            <Grid Margin="0,0,8,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="2*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SubPageFieldCell}">
                                    <TextBlock Text="Account code" Style="{StaticResource SubPageFormLabel}" />
                                    <TextBox Text="{Binding AccountCode, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SubPageFormInput}" />
                                </StackPanel>
                                <Button Grid.Column="1" Content="Look up" Command="{Binding LookupAccountCommand}"
                                        Style="{StaticResource SecondaryButton}" MinWidth="72" Height="28"
                                        VerticalAlignment="Bottom" Margin="0,0,8,6" ToolTip="Look up customer account from master" />
                                <StackPanel Grid.Column="2" Style="{StaticResource SubPageFieldCell}">
                                    <TextBlock Text="Account name" Style="{StaticResource SubPageFormLabel}" />
                                    <TextBox Text="{Binding AccountName, UpdateSourceTrigger=PropertyChanged}"
                                             IsReadOnly="True" Style="{StaticResource SubPageFormInput}" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Style="{StaticResource SubPageFieldCell}">
                                <TextBlock Text="Narration" Style="{StaticResource SubPageFormLabel}" />
                                <TextBox Text="{Binding Narration, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource SubPageFormMultiline}" Height="56" />
                            </StackPanel>

                            <CheckBox Content="Clear form after save (stay on entry for next voucher)"
                                      IsChecked="{Binding ClearAfterSave, Mode=TwoWay}"
                                      Margin="0,4,0,0"
                                      Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}" MinWidth="110" Margin="0,0,10,0">
                            <TextBlock Text="Save" Foreground="White" FontWeight="SemiBold" FontSize="12" />
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}" MinWidth="110">
                            <TextBlock Text="Cancel" FontSize="12" />
                        </Button>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Style="{StaticResource SubPageFooterNote}"
                               Text="Save posts the receipt to MongoDB and returns to the list unless “Clear form after save” is checked. Customer accounts are used for receipts." />
                </Grid>
            </Border>
        </Grid>
    </controls:TransactionEntryShell>
</UserControl>
