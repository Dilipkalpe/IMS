<Window x:Class="IMS.Views.BarcodeLabelPrintDialog"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        Title="Barcode Label Print"

        Height="640" Width="760"

        WindowStartupLocation="CenterOwner"

        ResizeMode="CanResizeWithGrip"

        MinWidth="640" MinHeight="520"

        ShowInTaskbar="False"

        Background="{DynamicResource TransactionPageBackgroundBrush}">

    <Border Style="{StaticResource TransactionShellBorder}" Margin="0">

        <Grid>

            <Grid.RowDefinitions>

                <RowDefinition Height="Auto" />

                <RowDefinition Height="*" />

                <RowDefinition Height="Auto" />

            </Grid.RowDefinitions>



            <Border Grid.Row="0" Style="{StaticResource TransactionTitleBar}">

                <StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">

                        <TextBlock Text="&#xE963;" FontFamily="{StaticResource IconFont}"

                                   FontSize="16" Foreground="{DynamicResource AccentBrush}"

                                   VerticalAlignment="Center" Margin="0,0,8,0" />

                        <TextBlock Text="Barcode label print" Style="{StaticResource TransactionTitleText}" />

                    </StackPanel>

                    <TextBlock x:Name="InvoiceCaption"

                               TextWrapping="Wrap" FontSize="12"

                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="24,0,0,0" />

                </StackPanel>

            </Border>



            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"

                          Background="{DynamicResource TransactionPageBackgroundBrush}"

                          Padding="10">

                <StackPanel>

                    <Border Style="{StaticResource TransactionSectionBorder}" Padding="10" Margin="0,0,0,8">

                        <StackPanel>

                            <TextBlock Text="LABEL SHEET LAYOUT" Style="{StaticResource FormLabel}" Margin="0,0,0,4" />

                            <TextBlock Text="Select a standard A4 sheet preset or choose Custom size below."

                                       TextWrapping="Wrap" FontSize="12"

                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8" />

                            <ComboBox x:Name="FormatCombo"

                                      Style="{StaticResource FormCombo}"

                                      Margin="0,0,0,8"

                                      MaxDropDownHeight="320" />

                            <TextBlock x:Name="FormatDescription"

                                       TextWrapping="Wrap" FontSize="12"

                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />



                            <Border x:Name="CustomSizePanel" Visibility="Collapsed"

                                    BorderBrush="{StaticResource TransactionShellBorderBrush}"

                                    BorderThickness="1" Padding="10" Margin="0,4,0,0"

                                    Background="{DynamicResource PanelMutedBrush}">

                                <Grid>

                                    <Grid.ColumnDefinitions>

                                        <ColumnDefinition Width="*" />

                                        <ColumnDefinition Width="12" />

                                        <ColumnDefinition Width="*" />

                                    </Grid.ColumnDefinitions>

                                    <StackPanel>

                                        <TextBlock Text="Width (mm)" Style="{StaticResource FormLabel}" Margin="0,0,0,4" />

                                        <TextBox x:Name="CustomWidthBox" Style="{StaticResource FormInput}" Text="50" />

                                    </StackPanel>

                                    <StackPanel Grid.Column="2">

                                        <TextBlock Text="Height (mm)" Style="{StaticResource FormLabel}" Margin="0,0,0,4" />

                                        <TextBox x:Name="CustomHeightBox" Style="{StaticResource FormInput}" Text="25" />

                                    </StackPanel>

                                </Grid>

                            </Border>

                        </StackPanel>

                    </Border>



                    <Border Style="{StaticResource TransactionSectionBorder}" Padding="10" Margin="0,0,0,8">

                        <StackPanel>

                            <TextBlock Text="PRINT SYMBOLOGY" Style="{StaticResource FormLabel}" Margin="0,0,0,8" />

                            <WrapPanel Margin="0,0,0,4">

                                <RadioButton x:Name="BarcodeTypeRadio" GroupName="LabelType"

                                             Content="Code 128 barcode" IsChecked="True"

                                             FontSize="12" Margin="0,0,24,6" />

                                <RadioButton x:Name="QrCodeTypeRadio" GroupName="LabelType"

                                             Content="QR code"

                                             FontSize="12" Margin="0,0,0,6" />

                            </WrapPanel>

                        </StackPanel>

                    </Border>



                    <Border Style="{StaticResource TransactionSectionBorder}" Padding="10">

                        <StackPanel>

                            <TextBlock Text="COPIES &amp; QUANTITY" Style="{StaticResource FormLabel}" Margin="0,0,0,8" />

                            <TextBlock Text="Number of copies (optional)" Style="{StaticResource FormLabel}" Margin="0,0,0,4" />

                            <TextBox x:Name="CopiesBox" Style="{StaticResource FormInput}" Width="120"

                                     HorizontalAlignment="Left" Margin="0,0,0,12" Text="1" />



                            <TextBlock Text="Print quantity source" Style="{StaticResource FormLabel}" Margin="0,0,0,6" />

                            <RadioButton x:Name="PurchaseQtyRadio" GroupName="QtySource" Content="Purchase quantity" IsChecked="True"

                                         FontSize="12" Margin="0,0,0,4" />

                            <RadioButton x:Name="CustomQtyRadio" GroupName="QtySource" Content="Custom quantity per line"

                                         FontSize="12" Margin="0,0,0,8" />



                            <Grid x:Name="CustomQtyPanel" Margin="16,0,0,0" IsEnabled="False">

                                <Grid.ColumnDefinitions>

                                    <ColumnDefinition Width="140" />

                                    <ColumnDefinition Width="160" />

                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Custom quantity" Style="{StaticResource FormLabel}" VerticalAlignment="Center" />

                                <TextBox x:Name="CustomQtyBox" Grid.Column="1" Style="{StaticResource FormInput}" Text="1" />

                            </Grid>

                        </StackPanel>

                    </Border>

                </StackPanel>

            </ScrollViewer>



            <Border Grid.Row="2" Background="White"

                    BorderBrush="{StaticResource TransactionShellBorderBrush}"

                    BorderThickness="0,1,0,0" Padding="10,8">

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                    <Button Content="Cancel" MinWidth="88" Margin="0,0,8,0"

                            Style="{StaticResource SecondaryButton}" IsCancel="True" Click="Cancel_OnClick" />

                    <Button Content="Generate labels" MinWidth="130"

                            Style="{StaticResource PrimaryButton}" IsDefault="True" Click="Generate_OnClick" />

                </StackPanel>

            </Border>

        </Grid>

    </Border>

</Window>

