<UserControl x:Class="IMS.Views.LedgerReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:IMS.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1200"
             VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
             Background="{DynamicResource ContentBackgroundBrush}">
    <UserControl.Resources>
        <Style x:Key="LedgerRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource SoListRowStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsOpening}" Value="True">
                    <Setter Property="Background" Value="#e7f1ff" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsTotal}" Value="True">
                    <Setter Property="Background" Value="#f1f3f6" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsClosing}" Value="True">
                    <Setter Property="Background" Value="#f1f3f6" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <views:StandardReportView>
        <views:StandardReportView.FilterContent>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,10">
                    <TextBlock Text="Date From" Style="{StaticResource SoListReportFieldLabel}" />
                    <DatePicker SelectedDate="{Binding DateFrom, Mode=TwoWay}" Height="32" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,12,10">
                    <TextBlock Text="Date To" Style="{StaticResource SoListReportFieldLabel}" />
                    <DatePicker SelectedDate="{Binding DateTo, Mode=TwoWay}" Height="32" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                            Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Style="{StaticResource SoListReportShowButton}" Command="{Binding ShowCommand}" Margin="0,0,8,0" />
                    <Button Style="{StaticResource SoListReportPrintButton}" Command="{Binding PrintCommand}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="Account Code" Style="{StaticResource SoListReportFieldLabel}" />
                    <TextBox Text="{Binding AccountCode, Mode=OneWay}" IsReadOnly="True"
                             Padding="8,6" FontSize="13" Background="#fafbfc" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="Account" Style="{StaticResource SoListReportFieldLabel}" />
                    <ComboBox ItemsSource="{Binding AccountOptions}"
                              SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                              DisplayMemberPath="Display"
                              Padding="8,6" FontSize="13" Style="{StaticResource FormCombo}" />
                </StackPanel>
            </Grid>
        </views:StandardReportView.FilterContent>

        <views:StandardReportView.GridContent>
            <DataGrid ItemsSource="{Binding Rows}"
                      Style="{StaticResource SoListOrdersGrid}"
                      ColumnHeaderStyle="{StaticResource SoListColumnHeader}"
                      RowStyle="{StaticResource LedgerRowStyle}"
                      CellStyle="{StaticResource SoListDataGridCell}"
                      AlternationCount="2"
                      MinRowHeight="42"
                      ColumnHeaderHeight="44"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Entry Date" Binding="{Binding EntryDate}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Entry Type" Binding="{Binding EntryType}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Entry No" Binding="{Binding EntryNo}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Particular" Binding="{Binding Particular}" Width="*" MinWidth="200">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="DR" Binding="{Binding DrDisplay}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListAmountCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="CR" Binding="{Binding CrDisplay}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListAmountCell}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsClosing}" Value="True">
                                        <Setter Property="Foreground" Value="#dc3545" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Manual No" Binding="{Binding ManualNo}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SoListCell}" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </views:StandardReportView.GridContent>

        <views:StandardReportView.FooterContent>
            <Grid HorizontalAlignment="Right">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Debit" FontWeight="SemiBold" FontSize="14" Foreground="#2c3e50"
                           VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Grid.Column="1" Text="{Binding FooterDebitDisplay}" FontWeight="SemiBold" FontSize="14"
                           Foreground="#dc3545" HorizontalAlignment="Right" />
                <TextBlock Grid.Column="3" Text="Credit" FontWeight="SemiBold" FontSize="14" Foreground="#2c3e50"
                           VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Grid.Column="4" Text="{Binding FooterCreditDisplay}" FontWeight="SemiBold" FontSize="14"
                           Foreground="#dc3545" HorizontalAlignment="Right" />
            </Grid>
        </views:StandardReportView.FooterContent>
    </views:StandardReportView>
</UserControl>
