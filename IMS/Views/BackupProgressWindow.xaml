<Window x:Class="IMS.Views.BackupProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Database Backup"
        Height="200" Width="460"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource AppDialogWindow}">
    <Border Style="{StaticResource AppDialogShell}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource AppDialogTitleBar}">
                <DockPanel LastChildFill="True">
                    <Border Style="{StaticResource AppDialogIconBadge}" DockPanel.Dock="Left">
                        <TextBlock Text="&#xE895;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Foreground="{DynamicResource AccentBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Creating database backup…"
                               Style="{StaticResource AppDialogTitleText}"
                               VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="20,16,20,20">
                <TextBlock x:Name="StatusText"
                           Text="Please wait while your data is backed up."
                           Style="{StaticResource AppDialogBodyText}"
                           Margin="0,0,0,14" />
                <ProgressBar Height="8"
                               IsIndeterminate="True"
                               Foreground="{DynamicResource AccentBrush}"
                               Background="{DynamicResource PanelMutedBrush}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
