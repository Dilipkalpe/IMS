<UserControl x:Class="IMS.Views.Controls.TransactionEntryBottomPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:IMS.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="80" d:DesignWidth="900">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,12,0">
            <TextBlock Text="Narration" Style="{StaticResource SalesFieldLabel}" />
            <TextBox Text="{Binding Narration, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SalesCompactInput}" Height="26" Margin="0,4,0,0" />
        </StackPanel>
        <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock Text="Actions" Style="{StaticResource SectionHeader}" FontSize="12" Margin="0,0,0,8" />
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource SalesSideButton}" Width="44" Height="44" Padding="0" Margin="0,0,6,0"
                        Command="{Binding NewBillCommand}" ToolTip="{Binding NewDocButtonText}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource IconText}" FontSize="16" Foreground="White" Text="&#xE710;" />
                        <TextBlock Text="New" FontSize="9" Foreground="White" HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SalesSideButton}" Width="44" Height="44" Padding="0" Margin="0,0,6,0"
                        Command="{Binding SaveCommand}" ToolTip="Save">
                    <StackPanel>
                        <TextBlock Style="{StaticResource IconText}" FontSize="16" Foreground="White" Text="&#xE74E;" />
                        <TextBlock Text="Save" FontSize="9" Foreground="White" HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SalesSideButtonSecondary}" Width="44" Height="44" Padding="0" Margin="0,0,6,0"
                        Command="{Binding SaveAndNextCommand}" ToolTip="Save, Next (F11)">
                    <StackPanel>
                        <TextBlock Style="{StaticResource IconText}" FontSize="16" Text="&#xE74E;" />
                        <TextBlock Text="Next" FontSize="9" HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SalesSideButton}" Width="44" Height="44" Padding="0" Margin="0,0,6,0"
                        Command="{Binding PrintSaveNextCommand}" ToolTip="Save, Print, Next (F12)">
                    <StackPanel>
                        <TextBlock Style="{StaticResource IconText}" FontSize="16" Foreground="White" Text="&#xE749;" />
                        <TextBlock Text="S+P" FontSize="9" Foreground="White" HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SalesSideButton}" Width="44" Height="44" Padding="0" Margin="0,0,6,0"
                        Command="{Binding RecordPaymentCommand}" ToolTip="Record Payment"
                        Visibility="{Binding ShowRecordPaymentAction, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource IconText}" FontSize="16" Foreground="White" Text="&#xE8C7;" />
                        <TextBlock Text="Pay" FontSize="9" Foreground="White" HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SalesSideButton}" Width="44" Height="44" Padding="0" Margin="0,0,6,0"
                        Command="{Binding PrintCommand}" ToolTip="Print">
                    <StackPanel>
                        <TextBlock Style="{StaticResource IconText}" FontSize="16" Foreground="White" Text="&#xE749;" />
                        <TextBlock Text="Print" FontSize="9" Foreground="White" HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SalesSideButtonSecondary}" Width="44" Height="44" Padding="0" Margin="0,0,6,0"
                        Command="{Binding PrintPreviousCommand}" ToolTip="{Binding PrintPreviousLabel}"
                        Visibility="{Binding ShowPrintPreviousAction, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource IconText}" FontSize="16" Text="&#xE7C3;" />
                        <TextBlock Text="Prev" FontSize="9" HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SalesSideButtonSecondary}" Width="44" Height="44" Padding="0" Margin="0,0,0,0"
                        Command="{Binding CloseCommand}" ToolTip="Close">
                    <StackPanel>
                        <TextBlock Style="{StaticResource IconText}" FontSize="16" Text="&#xE711;" />
                        <TextBlock Text="Close" FontSize="9" HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
