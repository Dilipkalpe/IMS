<UserControl x:Class="IMS.Views.Controls.DashboardLineChart"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="160"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="120" />
        </Grid.RowDefinitions>
        <TextBlock x:Name="TitleText" Grid.Row="0" FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4" />
        <StackPanel x:Name="LegendPanel" Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,4" />
        <Canvas x:Name="PlotCanvas" Grid.Row="2" ClipToBounds="True" />
    </Grid>
</UserControl>
