<UserControl x:Class="IMS.Views.Controls.ProductScanPickerBar"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             xmlns:conv="clr-namespace:IMS.Converters"

             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

             mc:Ignorable="d"

             d:DesignHeight="48" d:DesignWidth="900">

    <UserControl.Resources>

        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />

    </UserControl.Resources>

    <Border Style="{StaticResource TransactionScanBar}">

        <Grid>

            <!-- Standard: single row (Sales Order, wide layouts) -->

            <Grid x:Name="StandardLayout">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="Auto" />

                    <ColumnDefinition Width="160" MinWidth="120" />

                    <ColumnDefinition Width="*" MinWidth="180" />

                    <ColumnDefinition Width="Auto" />

                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Barcode scan" Style="{StaticResource SalesFieldLabel}"

                           Margin="0,0,8,0" VerticalAlignment="Center" />

                <TextBox x:Name="BarcodeProductBox" Grid.Column="1"

                         Text="{Binding BarcodeOrProduct, UpdateSourceTrigger=PropertyChanged}"

                         Style="{StaticResource SalesCompactInput}" Height="28"

                         PreviewKeyDown="BarcodeProductBox_OnPreviewKeyDown"

                         ToolTip="Scan barcode — row adds automatically when scan completes (Enter)" />

                <StackPanel Grid.Column="2" Margin="8,0,8,0"

                            Visibility="{Binding ShowProductPicker, Converter={StaticResource BoolToVis}}">

                    <ComboBox x:Name="ProductComboBox" Height="28"

                              ItemsSource="{Binding ProductOptions}"

                              Text="{Binding ProductSearchText, UpdateSourceTrigger=PropertyChanged}"

                              SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"

                              IsEditable="True"

                              IsTextSearchEnabled="False"

                              StaysOpenOnEdit="True"

                              Style="{StaticResource SubPageFormCombo}"

                              DropDownOpened="ProductComboBox_OnDropDownOpened"

                              ToolTip="Type 2+ characters to search products (max 40 matches)" />

                    <TextBlock Text="{Binding ProductSearchStatus}" FontSize="10" Margin="0,2,0,0"

                               Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" />

                </StackPanel>

                <Button Grid.Column="3" Content="Browse…" Command="{Binding BrowseProductsCommand}"

                        Style="{StaticResource SecondaryButton}" MinWidth="76" Height="28" Padding="12,0"

                        ToolTip="Open product list (search, paging)"

                        Visibility="{Binding ShowProductBrowse, Converter={StaticResource BoolToVis}}" />

            </Grid>



            <!-- Compact: stacked rows (BOM two-column layout) -->

            <StackPanel x:Name="CompactLayout" Visibility="Collapsed">

                <Grid Margin="0,0,0,4">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="Auto" />

                        <ColumnDefinition Width="*" MinWidth="80" />

                        <ColumnDefinition Width="Auto" />

                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Scan" Style="{StaticResource SalesFieldLabel}"

                               Margin="0,0,6,0" VerticalAlignment="Center" FontSize="11" />

                    <TextBox x:Name="BarcodeProductBoxCompact" Grid.Column="1"

                             Text="{Binding BarcodeOrProduct, UpdateSourceTrigger=PropertyChanged}"

                             Style="{StaticResource SalesCompactInput}" Height="26"

                             PreviewKeyDown="BarcodeProductBox_OnPreviewKeyDown"

                             ToolTip="Scan barcode, press Enter to add" />

                    <Button Grid.Column="2" Content="Browse…" Command="{Binding BrowseProductsCommand}"

                            Style="{StaticResource SecondaryButton}" MinWidth="64" Height="26" Padding="8,0" Margin="6,0,0,0"

                            Visibility="{Binding ShowProductBrowse, Converter={StaticResource BoolToVis}}" />

                </Grid>

                <ComboBox x:Name="ProductComboBoxCompact" Height="26"

                          ItemsSource="{Binding ProductOptions}"

                          Text="{Binding ProductSearchText, UpdateSourceTrigger=PropertyChanged}"

                          SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"

                          IsEditable="True"

                          IsTextSearchEnabled="False"

                          StaysOpenOnEdit="True"

                          Style="{StaticResource SubPageFormCombo}"

                          DropDownOpened="ProductComboBox_OnDropDownOpened"

                          Visibility="{Binding ShowProductPicker, Converter={StaticResource BoolToVis}}"

                          ToolTip="Search product" />

                <TextBlock Text="{Binding ProductSearchStatus}" FontSize="10" Margin="0,2,0,0"

                           Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"

                           Visibility="{Binding ShowProductPicker, Converter={StaticResource BoolToVis}}" />

            </StackPanel>

        </Grid>

    </Border>

</UserControl>

