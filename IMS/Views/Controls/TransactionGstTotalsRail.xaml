<UserControl x:Class="IMS.Views.Controls.TransactionGstTotalsRail"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="232">
    <StackPanel>
        <TextBlock Text="Totals + Payment" Style="{StaticResource SectionHeader}"
                   FontSize="14" FontWeight="Bold" Margin="0,0,0,8" />

        <TextBlock Text="Total Taxable Value" Style="{StaticResource SalesFieldLabel}" FontSize="13" />
        <TextBox Text="{Binding TotalTaxableDisplay, Mode=OneWay}" Style="{StaticResource SalesCompactInput}" IsReadOnly="True"
                 FontSize="14" Height="30" Background="{DynamicResource PanelMutedBrush}" Margin="0,2,0,4" />

        <TextBlock Text="Total CGST" Style="{StaticResource SalesFieldLabel}" FontSize="13" />
        <TextBox Text="{Binding TotalCgstDisplay, Mode=OneWay}" Style="{StaticResource SalesCompactInput}" IsReadOnly="True"
                 FontSize="14" Height="30" Background="{DynamicResource PanelMutedBrush}" Margin="0,2,0,4" />

        <TextBlock Text="Total SGST" Style="{StaticResource SalesFieldLabel}" FontSize="13" />
        <TextBox Text="{Binding TotalSgstDisplay, Mode=OneWay}" Style="{StaticResource SalesCompactInput}" IsReadOnly="True"
                 FontSize="14" Height="30" Background="{DynamicResource PanelMutedBrush}" Margin="0,2,0,4" />

        <TextBlock Text="Total IGST" Style="{StaticResource SalesFieldLabel}" FontSize="13" />
        <TextBox Text="{Binding TotalIgstDisplay, Mode=OneWay}" Style="{StaticResource SalesCompactInput}" IsReadOnly="True"
                 FontSize="14" Height="30" Background="{DynamicResource PanelMutedBrush}" Margin="0,2,0,4" />

        <TextBlock Text="Total Discount" Style="{StaticResource SalesFieldLabel}" FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource AccentBrush}" />
        <TextBox Text="{Binding TotalDiscountDisplay, Mode=OneWay}" Style="{StaticResource SalesCompactInput}" IsReadOnly="True"
                 FontSize="15" Height="32" FontWeight="SemiBold" Background="{DynamicResource CardBrush}" Margin="0,2,0,4" />

        <TextBlock Text="{Binding DocumentTotalLabel}" Style="{StaticResource SalesFieldLabel}" FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource AccentBrush}" Margin="0,4,0,0" />
        <TextBox Text="{Binding InvoiceTotalDisplay, Mode=OneWay}" Style="{StaticResource SalesCompactInput}" IsReadOnly="True"
                 FontSize="15" Height="32" FontWeight="SemiBold" Background="{DynamicResource CardBrush}" Margin="0,2,0,4" />

        <TextBlock Text="Paid" Style="{StaticResource SalesFieldLabel}" FontSize="13" />
        <TextBox Text="{Binding PaidAmountDisplay, Mode=OneWay}" Style="{StaticResource SalesCompactInput}" IsReadOnly="True"
                 FontSize="14" Height="30" Background="{DynamicResource PanelMutedBrush}" Margin="0,2,0,4" />

        <TextBlock Text="Balance" Style="{StaticResource SalesFieldLabel}" FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource AccentBrush}" />
        <TextBox Text="{Binding BalanceDueDisplay, Mode=OneWay}" Style="{StaticResource SalesCompactInput}" IsReadOnly="True"
                 FontSize="15" Height="32" FontWeight="SemiBold" Background="{DynamicResource CardBrush}" Margin="0,2,0,4" />

        <TextBlock Text="Round Off" Style="{StaticResource SalesFieldLabel}" FontSize="13" />
        <TextBox Text="{Binding RoundOffDisplay, Mode=OneWay}" Style="{StaticResource SalesCompactInput}" IsReadOnly="True"
                 FontSize="14" Height="30" Background="{DynamicResource PanelMutedBrush}" Margin="0,2,0,0" />
    </StackPanel>
</UserControl>
