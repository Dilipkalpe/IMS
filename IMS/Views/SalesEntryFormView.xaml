<UserControl x:Class="IMS.Views.SalesEntryFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1200"
             VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
             Background="{DynamicResource ContentBackgroundBrush}">
    <UserControl.Resources>
        <!-- 8 product rows × 24px + 26px header ≈ 218px visible without scroll -->
        <Style x:Key="SalesLineGrid" TargetType="DataGrid" BasedOn="{StaticResource CorporateDataGrid}">
            <Setter Property="RowHeight" Value="24" />
            <Setter Property="ColumnHeaderHeight" Value="26" />
            <Setter Property="MinHeight" Value="218" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HeadersVisibility" Value="Column" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="6,4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="140" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="224" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Bill + customer (compact) -->
        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}" Padding="8,6" Margin="0,0,6,4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="88" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" MinWidth="100" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding DocNoLabel}" Style="{StaticResource SalesFieldLabel}" />
                    <TextBox Grid.Column="1" Text="{Binding BillNo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SalesCompactInput}" />
                    <TextBlock Grid.Column="3" Text="Date" Style="{StaticResource SalesFieldLabel}" />
                    <TextBox Grid.Column="4" Text="{Binding BillDate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SalesCompactInput}" />
                    <TextBlock Grid.Column="6" Text="Sales Man" Style="{StaticResource SalesFieldLabel}" />
                    <ComboBox Grid.Column="7" ItemsSource="{Binding SalesMen}" Text="{Binding SalesMan, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True" Style="{StaticResource SalesCompactCombo}" />
                </Grid>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Customer" Style="{StaticResource SalesFieldLabel}" />
                    <ComboBox Grid.Column="1" ItemsSource="{Binding Customers}" SelectedItem="{Binding Customer}"
                              Style="{StaticResource SalesCompactCombo}" />
                    <Button Grid.Column="2" Width="26" Height="26" Margin="6,0"
                            Command="{Binding NewCustomerCommand}" Style="{StaticResource ActionButton}" Padding="0">
                        <TextBlock Text="+" Foreground="White" FontWeight="Bold" FontSize="13" />
                    </Button>
                    <TextBlock Grid.Column="3" Text="Details" Style="{StaticResource SalesFieldLabel}" Margin="6,0,6,0" />
                    <TextBox Grid.Column="4" Text="{Binding CustomerDetails, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SalesCompactInput}" />
                </Grid>
            </Grid>
        </Border>

        <!-- Quick entry -->
        <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource AccentLightBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8"
                Padding="8,6" Margin="0,0,6,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" MinWidth="80" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="56" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="64" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="64" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Bar code" Style="{StaticResource SalesFieldLabel}" />
                <TextBox Grid.Column="1" Text="{Binding BarCode, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SalesCompactInput}" />
                <TextBlock Grid.Column="3" Text="Product" Style="{StaticResource SalesFieldLabel}" />
                <TextBox Grid.Column="4" Text="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SalesCompactInput}" />
                <TextBlock Grid.Column="6" Text="Qty" Style="{StaticResource SalesFieldLabel}" />
                <TextBox Grid.Column="7" Text="{Binding QuickQty, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SalesCompactInput}" />
                <TextBlock Grid.Column="9" Text="MRP" Style="{StaticResource SalesFieldLabel}" />
                <TextBox Grid.Column="10" Text="{Binding Mrp, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SalesCompactInput}" />
                <TextBlock Grid.Column="12" Text="Rate" Style="{StaticResource SalesFieldLabel}" />
                <TextBox Grid.Column="13" Text="{Binding QuickRate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SalesCompactInput}" />
                <Button Grid.Column="15" Style="{StaticResource ActionButton}" Padding="10,4"
                        Command="{Binding AddLineCommand}" VerticalAlignment="Center">
                    <TextBlock Text="Add line" Foreground="White" FontWeight="SemiBold" FontSize="12" />
                </Button>
            </Grid>
        </Border>

        <!-- Line items — sized for ~8 rows before scroll -->
        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource Card}" Padding="0" Margin="0,0,6,4"
                VerticalAlignment="Stretch" MinHeight="224">
            <DataGrid Style="{StaticResource SalesLineGrid}"
                      ItemsSource="{Binding LineItems}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource CorporateDataGridColumnHeader}" />
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="{DynamicResource CardBrush}" />
                        <Setter Property="MinHeight" Value="24" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentLightBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Sr." Binding="{Binding Sr}" Width="36" IsReadOnly="True" />
                    <DataGridTextColumn Header="Code" Binding="{Binding ProductRetailCode}" Width="90" IsReadOnly="True" />
                    <DataGridTextColumn Header="Item Description" Binding="{Binding ItemDescription}" Width="*" MinWidth="120" IsReadOnly="True" />
                    <DataGridTextColumn Header="Qty" Binding="{Binding Qty}" Width="44" IsReadOnly="True" />
                    <DataGridTextColumn Header="Rate" Binding="{Binding Rate}" Width="64" IsReadOnly="True" />
                    <DataGridTextColumn Header="Disc %" Binding="{Binding DiscPercent}" Width="50" IsReadOnly="True" />
                    <DataGridTextColumn Header="Disc Val" Binding="{Binding DiscValue}" Width="58" IsReadOnly="True" />
                    <DataGridTextColumn Header="Tax" Binding="{Binding TaxType}" Width="52" IsReadOnly="True" />
                    <DataGridTextColumn Header="Tax %" Binding="{Binding TaxPercent}" Width="50" IsReadOnly="True" />
                    <DataGridTextColumn Header="Amount" Binding="{Binding Amount}" Width="72" IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer (compact) -->
        <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource Card}" Padding="8,6" Margin="0,0,6,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Cust. Return" Style="{StaticResource SalesFieldLabel}" Width="88" FontSize="11" />
                        <TextBox Text="{Binding CustomerReturn, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SalesCompactInput}" Width="80" Height="24" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Receivable" Style="{StaticResource SalesFieldLabel}" Width="88" FontSize="11" />
                        <TextBox Text="{Binding ReceivableToCustomer, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SalesCompactInput}" Width="80" Height="24" />
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Column="1" Margin="10,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Narration" Style="{StaticResource SalesFieldLabel}" FontSize="11" VerticalAlignment="Center" />
                    <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="4" Text="{Binding Narration, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SalesCompactInput}" Height="24" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Tot Qty" Style="{StaticResource SalesFieldLabel}" FontSize="11" Margin="0,4,6,0" />
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TotQty}" Style="{StaticResource SalesCompactInput}" IsReadOnly="True" Height="24" Margin="0,4,0,0"
                             Background="{DynamicResource PanelMutedBrush}" />
                    <TextBlock Grid.Row="1" Grid.Column="3" Text="Gross" Style="{StaticResource SalesFieldLabel}" FontSize="11" Margin="0,4,6,0" />
                    <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding Gross}" Style="{StaticResource SalesCompactInput}" IsReadOnly="True" Height="24" Margin="0,4,0,0"
                             Background="{DynamicResource PanelMutedBrush}" />
                </Grid>

                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                        <TextBlock Text="Discount" Style="{StaticResource SalesFieldLabel}" Width="82" FontSize="11" />
                        <TextBox Text="{Binding Discount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SalesCompactInput}" Width="88" Height="24" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                        <TextBlock Text="Sp. Disc." Style="{StaticResource SalesFieldLabel}" Width="82" FontSize="11" />
                        <TextBox Text="{Binding SpDiscount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SalesCompactInput}" Width="88" Height="24" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                        <TextBlock Text="Add other" Style="{StaticResource SalesFieldLabel}" Width="82" FontSize="11" />
                        <TextBox Text="{Binding AddOther, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SalesCompactInput}" Width="88" Height="24" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                        <TextBlock Text="Net" Style="{StaticResource SalesFieldLabel}" Width="82" FontSize="11" />
                        <TextBox Text="{Binding Net}" Style="{StaticResource SalesCompactInput}" Width="88" Height="24" IsReadOnly="True"
                                 Background="{DynamicResource PanelMutedBrush}" FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding AmountTotalLabel}" Style="{StaticResource SalesFieldLabel}" Width="82" FontSize="11" FontWeight="Bold" />
                        <TextBox Text="{Binding SaleAmount}" Style="{StaticResource SalesCompactInput}" Width="88" Height="24" IsReadOnly="True"
                                 FontWeight="Bold" Background="{DynamicResource AccentLightBrush}"
                                 Foreground="{DynamicResource AccentBrush}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Actions -->
        <Border Grid.Row="0" Grid.RowSpan="4" Grid.Column="1" Style="{StaticResource Card}" Padding="8,6" VerticalAlignment="Stretch">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="Actions" Style="{StaticResource SectionHeader}" FontSize="12" Margin="0,0,0,6" />
                    <Button Style="{StaticResource SalesSideButton}" Command="{Binding NewBillCommand}">
                        <TextBlock Text="{Binding NewDocButtonText}" Foreground="White" FontWeight="SemiBold" />
                    </Button>
                    <Button Style="{StaticResource SalesSideButton}" Command="{Binding SaveCommand}">
                        <TextBlock Text="Save" Foreground="White" FontWeight="SemiBold" />
                    </Button>
                    <Button Content="Edit (F2)" Style="{StaticResource SalesSideButtonSecondary}" IsEnabled="False" />
                    <Button Style="{StaticResource SalesSideButton}" Command="{Binding PrintCommand}">
                        <TextBlock Text="Print" Foreground="White" FontWeight="SemiBold" />
                    </Button>
                    <Button Content="Search (F9)" Style="{StaticResource SalesSideButtonSecondary}" IsEnabled="False" />
                    <Button Style="{StaticResource SalesSideButton}" Command="{Binding PrintSaveNextCommand}">
                        <TextBlock Text="Save, Print, Next (F12)" Foreground="White" FontWeight="SemiBold" FontSize="10" TextWrapping="Wrap" TextAlignment="Center" />
                    </Button>
                    <Button Content="Save, Next (F11)" Style="{StaticResource SalesSideButtonSecondary}" IsEnabled="False" FontSize="10" />
                    <Button Content="Delete" Style="{StaticResource SalesSideButtonSecondary}" IsEnabled="False" />
                    <Button Style="{StaticResource SalesSideButtonSecondary}" Command="{Binding PrintPreviousCommand}">
                        <TextBlock Text="{Binding PrintPreviousLabel}" FontSize="10" TextWrapping="Wrap" TextAlignment="Center" />
                    </Button>
                    <Button Content="Edit Previous" Style="{StaticResource SalesSideButtonSecondary}" IsEnabled="False" FontSize="10" />
                    <Button Content="Sales Return" Style="{StaticResource SalesSideButtonSecondary}" IsEnabled="False" />
                    <Button Content="Cancel (F7)" Style="{StaticResource SalesSideButtonSecondary}" Command="{Binding CancelCommand}" />
                    <Button Content="Close" Style="{StaticResource SalesSideButtonSecondary}" Command="{Binding CloseCommand}" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
