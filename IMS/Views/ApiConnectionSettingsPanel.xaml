<UserControl x:Class="IMS.Views.ApiConnectionSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:IMS.Converters"
             mc:Ignorable="d"
             d:DesignHeight="220" d:DesignWidth="700">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <StackPanel>
        <TextBlock Text="API &amp; web connection" Style="{StaticResource SectionHeader}" />
        <TextBlock Text="Choose how this desktop app connects to the server. Use IIS — IMSWebAPI when the API is deployed on IIS. Open IMSWebApp in the browser for the React web client."
                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,12" />

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Connection" Style="{StaticResource FormLabel}" VerticalAlignment="Center" />
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding Profiles}"
                      SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                      Style="{StaticResource FormCombo}"
                      MinWidth="280">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </Grid>

        <TextBlock Text="{Binding SelectedProfile.Description}"
                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" Margin="140,0,0,12" />

        <Grid Margin="0,0,0,8" Visibility="{Binding IsIisProfileSelected, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="IIS server" Style="{StaticResource FormLabel}" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding IisServerHost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Height="36" Padding="10,6" VerticalContentAlignment="Center"
                     ToolTip="PC name or IP where IIS hosts IMSWebAPI and IMSWebApp (e.g. localhost)" />
        </Grid>

        <Grid Margin="0,0,0,8" Visibility="{Binding IsCustomProfileSelected, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="API URL" Style="{StaticResource FormLabel}" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding CustomApiUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Height="36" Padding="10,6" VerticalContentAlignment="Center"
                     ToolTip="Base URL without /api suffix" />
        </Grid>

        <Grid Margin="0,0,0,8" Visibility="{Binding ShowWebAppLink, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Web app URL" Style="{StaticResource FormLabel}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Text="{Binding ResolvedWebAppUrl}" FontSize="12" TextWrapping="Wrap"
                       Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,10,0" />
            <Button Grid.Column="2" Content="Open IMSWebApp"
                    Command="{Binding OpenWebAppCommand}"
                    Style="{StaticResource SecondaryButton}" Padding="12,8" />
        </Grid>

        <Border Style="{StaticResource HighlightPanel}" Margin="0,4,0,12">
            <StackPanel>
                <TextBlock Text="Resolved API URL" FontWeight="SemiBold" FontSize="12"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock Text="{Binding ResolvedApiUrl}" Margin="0,6,0,0"
                           Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal">
            <Button Content="Test connection" Command="{Binding TestConnectionCommand}"
                    Style="{StaticResource SecondaryButton}" Padding="14,8" Margin="0,0,10,0" />
            <Button Content="Save connection" Command="{Binding SaveConnectionCommand}"
                    Style="{StaticResource PrimaryButton}" Padding="14,8" />
        </StackPanel>

        <TextBlock Text="{Binding StatusMessage}" FontSize="12" TextWrapping="Wrap"
                   Foreground="{DynamicResource AccentBrush}" Margin="0,10,0,0" />
    </StackPanel>
</UserControl>
