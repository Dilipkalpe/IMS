<Window x:Class="IMS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:IMS.ViewModels"
        xmlns:subvm="clr-namespace:IMS.ViewModels.SubPages"
        xmlns:reportvm="clr-namespace:IMS.Reporting.Designer.ViewModels"
        xmlns:reportviews="clr-namespace:IMS.Reporting.Designer.Views"
        xmlns:views="clr-namespace:IMS.Views"
        xmlns:converters="clr-namespace:IMS.Converters"
        xmlns:models="clr-namespace:IMS.Models"
        xmlns:services="clr-namespace:IMS.Services"
        mc:Ignorable="d"
        Title="IMS — Inventory Management System"
        Height="780" Width="1280"
        MinHeight="540" MinWidth="960"
        WindowState="Maximized"
        WindowStartupLocation="Manual"
        ResizeMode="CanResize"
        Background="{StaticResource TransactionPageBackgroundBrush}"
        PreviewKeyDown="MainWindow_OnPreviewKeyDown">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type subvm:AddProductViewModel}">
            <views:ProductMasterFormView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type subvm:AddAccountMasterViewModel}">
            <views:AccountMasterFormView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type subvm:DynamicFormViewModelBase}">
            <views:DynamicFormView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type subvm:SalesOrderWorkspaceViewModel}">
            <views:SalesOrderWorkspaceView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type subvm:DeliveryChallanWorkspaceViewModel}">
            <views:DeliveryChallanWorkspaceView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type subvm:SalesInvoiceWorkspaceViewModel}">
            <views:SalesInvoiceWorkspaceView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type subvm:SalesReturnWorkspaceViewModel}">
            <views:SalesReturnWorkspaceView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type subvm:PurchaseOrderWorkspaceViewModel}">
            <views:PurchaseOrderWorkspaceView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type subvm:GrnWorkspaceViewModel}">
            <views:GrnWorkspaceView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type subvm:PurchaseInvoiceWorkspaceViewModel}">
            <views:PurchaseInvoiceWorkspaceView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type subvm:PurchaseReturnWorkspaceViewModel}">
            <views:PurchaseReturnWorkspaceView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type subvm:StockTransferViewModel}">
            <views:StockTransferView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type subvm:PaymentVoucherEntryViewModel}">
            <views:PaymentVoucherEntryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type subvm:ReceiptVoucherEntryViewModel}">
            <views:ReceiptVoucherEntryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type subvm:CreditNoteEntryViewModel}">
            <views:CreditNoteEntryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type subvm:DebitNoteEntryViewModel}">
            <views:DebitNoteEntryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type subvm:CashEntryEntryViewModel}">
            <views:CashEntryEntryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type subvm:BankEntryEntryViewModel}">
            <views:BankEntryEntryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type subvm:WorkOrderViewModel}">
            <views:WorkOrderView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type subvm:BomViewModel}">
            <views:BomView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type subvm:AddPayrollEmployeeViewModel}">
            <views:PayrollEmployeeFormView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type subvm:FormSubPageViewModel}">
            <views:SubPageView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductsViewModel}">
            <views:StandardListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type subvm:BillFormatDesignViewModel}">
            <views:BillFormatDesignerView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type reportvm:ReportFormatDesignerViewModel}">
            <reportviews:ReportFormatDesignerView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FinancialYearManagementViewModel}">
            <views:FinancialYearManagementView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RoleMasterViewModel}">
            <views:RoleMasterView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RoleFormViewModel}">
            <views:RoleFormView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SalesOrdersViewModel}">
            <views:StandardListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MockPageViewModel}">
            <views:StandardListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:OpeningStockReportViewModel}">
            <views:OpeningStockReportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ClosingStockReportViewModel}">
            <views:ClosingStockReportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StockMovementReportViewModel}">
            <views:StockMovementReportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StockDetailsSummaryReportViewModel}">
            <views:StockDetailsSummaryReportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LedgerReportViewModel}">
            <views:LedgerReportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TrialBalanceReportViewModel}">
            <views:TrialBalanceReportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TradingAccountReportViewModel}">
            <views:FinancialStatementReportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProfitLossReportViewModel}">
            <views:FinancialStatementReportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProfitLossWithTradingReportViewModel}">
            <views:FinancialStatementReportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BalanceSheetReportViewModel}">
            <views:FinancialStatementReportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReorderLevelReportViewModel}">
            <views:ReorderLevelReportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProfitAnalysisReportViewModel}">
            <views:ProfitAnalysisReportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PurchaseAnalysisReportViewModel}">
            <views:PurchaseAnalysisReportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SalesAnalysisReportViewModel}">
            <views:SalesAnalysisReportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:OutstandingReportViewModel}">
            <views:OutstandingReportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DueDayReportViewModel}">
            <views:DueDayReportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DueAmountReportViewModel}">
            <views:DueAmountReportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DocumentRegisterReportViewModel}">
            <views:DocumentRegisterReportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ImportPageViewModel}">
            <views:ImportPageView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HubViewModel}">
            <views:HubView />
        </DataTemplate>

        <converters:StringEqualityConverter x:Key="StringEqualityConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibility" Invert="True" />
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Width="{Binding SidebarWidth}"
                Background="{StaticResource SidebarBrush}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="16,16,16,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8" Background="{DynamicResource SidebarSelectedBrush}">
                            <Grid>
                                <TextBlock Style="{StaticResource IconText}" FontSize="18" Foreground="{DynamicResource SidebarTextBrush}" Text="&#xE7B8;"
                                           Visibility="{Binding HasSidebarLogo, Converter={StaticResource InvertedBoolToVisibility}}" />
                                <Image Source="{Binding SidebarLogo}" Stretch="Uniform" Margin="3"
                                       Visibility="{Binding HasSidebarLogo, Converter={StaticResource BoolToVisibility}}" />
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center"
                                    Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InvertedBoolToVisibility}}">
                            <TextBlock Text="{Binding SidebarTitle}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource SidebarTextBrush}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding SidebarSubtitle}" FontSize="10" Foreground="{DynamicResource SidebarTextMutedBrush}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Inventory Management with Production (BOM)"
                               Foreground="{DynamicResource SidebarTextMutedBrush}" FontSize="10" TextWrapping="Wrap" Margin="0,8,0,0"
                               Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InvertedBoolToVisibility}}" />
                </StackPanel>

                <Border DockPanel.Dock="Bottom" Padding="10" BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16" Background="{DynamicResource SidebarActiveBrush}">
                            <TextBlock Style="{StaticResource IconText}" FontSize="14" Foreground="{DynamicResource SidebarTextBrush}" Text="&#xE77B;" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="8,0,6,0" VerticalAlignment="Center"
                                    Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InvertedBoolToVisibility}}">
                            <TextBlock Text="{x:Static services:AuthSession.DisplayName}" Foreground="{DynamicResource SidebarTextBrush}" FontWeight="SemiBold" FontSize="12" />
                            <TextBlock Text="{x:Static services:AuthSession.RoleLabel}" Foreground="{DynamicResource SidebarTextMutedBrush}" FontSize="10" />
                        </StackPanel>
                        <Button Grid.Column="2"
                                Command="{Binding LogoutCommand}"
                                Style="{StaticResource NavSidebarIconButton}"
                                ToolTip="Sign out"
                                Padding="6,5"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconText}" FontSize="14" Text="&#xE7E8;" Foreground="{DynamicResource SidebarTextBrush}" />
                                <TextBlock Text="Sign out" FontSize="10" Foreground="{DynamicResource SidebarTextMutedBrush}" Margin="6,0,0,0" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InvertedBoolToVisibility}}" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <StackPanel DockPanel.Dock="Top" Margin="8,0,8,6"
                            Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InvertedBoolToVisibility}}">
                    <TextBlock Text="Search menu" Foreground="{DynamicResource SidebarTextMutedBrush}"
                               FontSize="10" Margin="0,0,0,3" />
                    <Border Margin="0,0,0,6"
                            Background="{DynamicResource SidebarActiveBrush}"
                            BorderBrush="{DynamicResource SidebarBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="3,2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="28" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource IconText}"
                                       FontSize="13"
                                       Text="&#xE721;"
                                       Foreground="{DynamicResource SidebarTextBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       ToolTip="Search" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding MenuSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource NavSidebarSearchBoxInner}"
                                     BorderThickness="0"
                                     Background="Transparent" />
                            <Button Grid.Column="2"
                                    Command="{Binding ClearMenuSearchCommand}"
                                    Style="{StaticResource NavSidebarIconButton}"
                                    ToolTip="Clear search"
                                    Padding="0"
                                    Width="24"
                                    Height="24"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                                <TextBlock Style="{StaticResource IconText}"
                                           FontSize="11"
                                           Text="&#xE8BB;"
                                           Foreground="{DynamicResource SidebarTextBrush}" />
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="8,0,0,8"
                              Visibility="{Binding ShowNavigationMenu, Converter={StaticResource BoolToVisibility}}">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar">
                            <Setter Property="Width" Value="8" />
                        </Style>
                    </ScrollViewer.Resources>
                    <StackPanel Margin="0,0,8,0">
                        <ItemsControl ItemsSource="{Binding NavigationSections}"
                                      Visibility="{Binding ShowFavoritesSection, Converter={StaticResource BoolToVisibility}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:NavigationSectionViewModel}">
                                    <StackPanel Margin="0,0,0,6">
                                        <TextBlock Text="Favorites"
                                                   Foreground="{DynamicResource SidebarTextMutedBrush}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Margin="6,6,0,2"
                                                   Visibility="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InvertedBoolToVisibility}}" />
                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type models:NavigationItem}">
                                                    <Grid Margin="0,1">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Button Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                ToolTip="{Binding Title}">
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Value="True">
                                                                            <DataTrigger.Binding>
                                                                                <MultiBinding Converter="{StaticResource StringEqualityConverter}">
                                                                                    <Binding Path="DataContext.SelectedNavigationKey" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                                                    <Binding Path="Key" />
                                                                                </MultiBinding>
                                                                            </DataTrigger.Binding>
                                                                            <Setter Property="Background" Value="{DynamicResource SidebarActiveBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                                                                            <Setter Property="Padding" Value="6,5" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Style="{StaticResource IconText}"
                                                                           FontSize="14"
                                                                           Foreground="{DynamicResource SidebarTextMutedBrush}"
                                                                           Text="{Binding IconGlyph}" />
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Title}"
                                                                           Foreground="{DynamicResource SidebarTextBrush}"
                                                                           FontSize="12"
                                                                           VerticalAlignment="Center"
                                                                           Margin="8,0,0,0"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           TextWrapping="NoWrap"
                                                                           Visibility="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InvertedBoolToVisibility}}" />
                                                            </Grid>
                                                        </Button>
                                                        <Button Grid.Column="1"
                                                                Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource NavPinButton}"
                                                                ToolTip="Unpin from favorites"
                                                                VerticalAlignment="Center"
                                                                Margin="0,0,2,0"
                                                                Visibility="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InvertedBoolToVisibility}}">
                                                            <TextBlock FontSize="14">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource IconText}">
                                                                        <Setter Property="Foreground" Value="{DynamicResource SidebarSelectedBrush}" />
                                                                        <Setter Property="Text" Value="&#xEB52;" />
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Button>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding SidebarNavItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:SidebarNavItemViewModel}">
                                    <Button Command="{Binding DataContext.NavigateSidebarCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{Binding Title}"
                                            Margin="0,1">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{StaticResource StringEqualityConverter}">
                                                                <Binding Path="DataContext.SelectedSidebarKey" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                                <Binding Path="Key" />
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="Background" Value="{DynamicResource SidebarActiveBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                                                        <Setter Property="Padding" Value="6,5" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Style="{StaticResource IconText}"
                                                       FontSize="14"
                                                       Foreground="{DynamicResource SidebarTextMutedBrush}"
                                                       Text="{Binding IconGlyph}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Title}"
                                                       Foreground="{DynamicResource SidebarTextBrush}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"
                                                       Margin="8,0,0,0"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap"
                                                       Visibility="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InvertedBoolToVisibility}}" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="8,0,0,8"
                              Visibility="{Binding IsMenuSearchActive, Converter={StaticResource BoolToVisibility}}">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar">
                            <Setter Property="Width" Value="8" />
                        </Style>
                    </ScrollViewer.Resources>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="No matching menu items"
                                   Foreground="{DynamicResource SidebarTextMutedBrush}"
                                   FontSize="11"
                                   Margin="6,8"
                                   Visibility="{Binding ShowMenuSearchEmpty, Converter={StaticResource BoolToVisibility}}" />
                        <ItemsControl ItemsSource="{Binding MenuSearchResults}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:NavigationItem}">
                                    <Button Command="{Binding DataContext.NavigateFromMenuSearchCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource NavButton}"
                                            ToolTip="{Binding Title}"
                                            Margin="0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Style="{StaticResource IconText}"
                                                       FontSize="14"
                                                       Foreground="{DynamicResource SidebarTextMutedBrush}"
                                                       Text="{Binding IconGlyph}" />
                                            <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center"
                                                        Visibility="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InvertedBoolToVisibility}}">
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="{DynamicResource SidebarTextBrush}"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Section}"
                                                           Foreground="{DynamicResource SidebarTextMutedBrush}"
                                                           FontSize="10"
                                                           Margin="0,1,0,0"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border x:Name="ContentHeader" Padding="24,10">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource TransactionTitleBar}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding UsesFullPageLayout}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Command="{Binding ToggleSidebarCollapseCommand}"
                                Style="{StaticResource NavButton}"
                                Padding="6"
                                Margin="0,0,8,0"
                                Background="{DynamicResource PanelMutedBrush}"
                                ToolTip="Collapse or expand navigation menu">
                            <TextBlock Style="{StaticResource IconText}" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" Text="&#xE700;" />
                        </Button>
                        <Button Command="{Binding GoBackCommand}" Padding="6" Margin="0,0,8,0"
                                Background="{DynamicResource PanelMutedBrush}" ToolTip="Back">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSubPage}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Style="{StaticResource IconText}" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" Text="&#xE72B;" />
                        </Button>
                        <TextBlock Style="{StaticResource IconText}" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" Opacity="0.7" Text="&#xE80F;" Margin="0,0,8,0" />
                        <TextBlock Text="IMS" Foreground="{DynamicResource TextPrimaryBrush}" Opacity="0.7" FontSize="13" />
                        <TextBlock Text="  /  " Foreground="{StaticResource TransactionShellBorderBrush}" />
                        <TextBlock Text="{Binding HeaderTitle, FallbackValue=Overview}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="13" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Border Style="{StaticResource ToolbarBadge}" Margin="0,0,8,0">
                            <TextBlock Text="{Binding ThemeBadgeText}" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" />
                        </Border>
                        <Button Style="{StaticResource NavButton}" Padding="8" Background="{DynamicResource PanelMutedBrush}" IsEnabled="False">
                            <TextBlock Style="{StaticResource IconText}" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Text="&#xE721;" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="ContentHost" Grid.Row="1" Padding="0">
                <ContentControl Content="{Binding CurrentViewModel}"
                                VerticalAlignment="Stretch"
                                HorizontalAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                HorizontalContentAlignment="Stretch" />
            </Border>
        </Grid>
    </Grid>
</Window>
