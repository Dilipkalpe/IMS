<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Premium IMS login — indigo / violet / cyan -->
    <Color x:Key="Login.Accent">#6366F1</Color>
    <Color x:Key="Login.Accent2">#8B5CF6</Color>
    <Color x:Key="Login.Accent3">#22D3EE</Color>
    <Color x:Key="Login.Primary">#6366F1</Color>
    <Color x:Key="Login.PrimaryDark">#4F46E5</Color>
    <Color x:Key="Login.Indigo">#8B5CF6</Color>
    <Color x:Key="Login.IndigoDeep">#312E81</Color>
    <Color x:Key="Login.Surface">#0A0A0F</Color>
    <Color x:Key="Login.SurfaceLight">#F4F6FB</Color>
    <Color x:Key="Login.Card">#FFFFFF</Color>
    <Color x:Key="Login.CardGlass">#1AFFFFFF</Color>
    <Color x:Key="Login.Border">#E2E8F0</Color>
    <Color x:Key="Login.BorderGlass">#33FFFFFF</Color>
    <Color x:Key="Login.Text">#0F172A</Color>
    <Color x:Key="Login.TextLight">#F8FAFC</Color>
    <Color x:Key="Login.TextMuted">#64748B</Color>
    <Color x:Key="Login.TextMutedLight">#94A3B8</Color>
    <Color x:Key="Login.Error">#F87171</Color>
    <Color x:Key="Login.ErrorBg">#FEF2F2</Color>
    <Color x:Key="Login.HeroStart">#1E1B4B</Color>
    <Color x:Key="Login.HeroMid">#4F46E5</Color>
    <Color x:Key="Login.HeroEnd">#0F172A</Color>

    <SolidColorBrush x:Key="LoginPrimaryBrush" Color="{StaticResource Login.Accent}" />
    <SolidColorBrush x:Key="LoginAccent3Brush" Color="{StaticResource Login.Accent3}" />
    <SolidColorBrush x:Key="LoginTextBrush" Color="{StaticResource Login.Text}" />
    <SolidColorBrush x:Key="LoginTextMutedBrush" Color="{StaticResource Login.TextMuted}" />
    <SolidColorBrush x:Key="LoginInputBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="LoginInputBorderBrush" Color="#CBD5E1" />
    <SolidColorBrush x:Key="LoginChromeBackgroundBrush" Color="#18FFFFFF" />
    <SolidColorBrush x:Key="LoginChromeBorderBrush" Color="#28FFFFFF" />
    <SolidColorBrush x:Key="LoginErrorBrush" Color="{StaticResource Login.Error}" />
    <SolidColorBrush x:Key="LoginErrorBgBrush" Color="#26F87171" />
    <SolidColorBrush x:Key="LoginCardBrush" Color="#18FFFFFF" />
    <SolidColorBrush x:Key="LoginBorderBrush" Color="#28FFFFFF" />

    <LinearGradientBrush x:Key="LoginHeroGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource Login.HeroStart}" Offset="0" />
        <GradientStop Color="{StaticResource Login.HeroMid}" Offset="0.5" />
        <GradientStop Color="{StaticResource Login.HeroEnd}" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="LoginPageBackground" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0A0A0F" Offset="0" />
        <GradientStop Color="#0F172A" Offset="0.5" />
        <GradientStop Color="#0A0A0F" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="LoginPageBackgroundLight" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F4F6FB" Offset="0" />
        <GradientStop Color="#EEF2FF" Offset="0.5" />
        <GradientStop Color="#F8FAFC" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="LoginButtonGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource Login.Accent}" Offset="0" />
        <GradientStop Color="{StaticResource Login.Accent2}" Offset="0.55" />
        <GradientStop Color="#7C3AED" Offset="1" />
    </LinearGradientBrush>

    <Style x:Key="LoginEyebrow" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource LoginAccent3Brush}" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style x:Key="LoginHeroTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="34" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="40" />
    </Style>

    <Style x:Key="LoginHeroAccent" TargetType="TextBlock">
        <Setter Property="FontSize" Value="34" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="#A5B4FC" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="LoginModulePill" TargetType="Border">
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Margin" Value="0,0,8,8" />
        <Setter Property="Background" Value="#18FFFFFF" />
        <Setter Property="BorderBrush" Value="#28FFFFFF" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="LoginModulePillText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#C7D2FE" />
    </Style>

    <!-- Login inputs use default WPF templates (Border wrapper in LoginWindow.xaml). -->

    <Style x:Key="LoginPrimaryButton" TargetType="Button">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="MinHeight" Value="56" />
        <Setter Property="Padding" Value="0,18" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" CornerRadius="12" Padding="{TemplateBinding Padding}"
                            Background="{StaticResource LoginButtonGradient}">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.45" Color="#6366F1" />
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.92" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="LoginIconButton" TargetType="Button">
        <Setter Property="Width" Value="54" />
        <Setter Property="Height" Value="54" />
        <Setter Property="MinWidth" Value="54" />
        <Setter Property="MinHeight" Value="54" />
        <Setter Property="Background" Value="{DynamicResource LoginChromeBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource LoginChromeBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="LoginCloseButton" TargetType="Button" BasedOn="{StaticResource LoginIconButton}">
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="44" />
        <Setter Property="MinWidth" Value="44" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="ToolTip" Value="Close" />
    </Style>

    <Style x:Key="LoginGhostButton" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource LoginChromeBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource LoginTextMutedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource LoginChromeBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="LoginFieldLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource LoginTextMutedBrush}" />
        <Setter Property="Margin" Value="2,0,0,8" />
    </Style>

    <Style x:Key="LoginGlassCard" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource LoginCardBrush}" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="40,36" />
        <Setter Property="BorderBrush" Value="{DynamicResource LoginBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.35" Color="#6366F1" />
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
