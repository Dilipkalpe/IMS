<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:IMS.Converters"
                    xmlns:controls="clr-namespace:IMS.Views.Controls">

    <!-- Theme dictionary is injected at runtime by ThemeService -->

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="StandardListStyles.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <converters:StatusToBrushConverter x:Key="StatusToBrushConverter" />
    <converters:StatusToForegroundConverter x:Key="StatusToForegroundConverter" />
    <converters:HexToBrushConverter x:Key="HexToBrushConverter" />
    <converters:HexToLightBrushConverter x:Key="HexToLightBrushConverter" />
    <converters:CellValueConverter x:Key="CellValueConverter" />
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

    <FontFamily x:Key="AppFont">Segoe UI</FontFamily>
    <FontFamily x:Key="IconFont">Segoe MDL2 Assets</FontFamily>

    <!-- Global control defaults -->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
    </Style>
    <Style TargetType="ComboBox">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
    </Style>
    <Style TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
    </Style>

    <Style x:Key="IconText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource IconFont}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="PageIconHost" TargetType="Border">
        <Setter Property="Width" Value="48" />
        <Setter Property="Height" Value="48" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Background" Value="{DynamicResource AccentLightBrush}" />
    </Style>

    <Style x:Key="PageIconHostLarge" TargetType="Border" BasedOn="{StaticResource PageIconHost}">
        <Setter Property="Width" Value="56" />
        <Setter Property="Height" Value="56" />
        <Setter Property="CornerRadius" Value="14" />
    </Style>

    <Style x:Key="StatIconHost" TargetType="Border">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="{DynamicResource PanelMutedBrush}" />
    </Style>

    <Style x:Key="NavSectionHeaderButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,10" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SidebarHoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NavPinButton" TargetType="Button">
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SidebarHoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NavSidebarSearchBox" TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource SidebarActiveBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SidebarBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="CaretBrush" Value="{DynamicResource SidebarTextBrush}" />
    </Style>

    <Style x:Key="NavSidebarSearchBoxInner" TargetType="TextBox" BasedOn="{StaticResource NavSidebarSearchBox}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4,5,4,5" />
    </Style>

    <Style x:Key="NavSidebarIconButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SidebarHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NavSidebarToolButton" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource SidebarActiveBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SidebarBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SidebarHoverBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NavSectionChevron" TargetType="TextBlock" BasedOn="{StaticResource IconText}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Text" Value="&#xE70D;" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                <Setter Property="Text" Value="&#xE76C;" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="NavButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SidebarHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SidebarActiveBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource CardBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.08" Color="{DynamicResource Theme.Shadow}" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HighlightPanel" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource AccentLightBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <Style x:Key="PageTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="PageSubtitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <Style x:Key="GridHeader" TargetType="TextBlock">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="MockBadge" TargetType="Border">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

    <Style x:Key="SectionHeader" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style x:Key="DashboardHeroBanner" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SidebarBrush}" />
        <Setter Property="Padding" Value="28,22,28,20" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style x:Key="DashboardInnerCard" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="MinHeight" Value="56" />
    </Style>

    <Style x:Key="DashboardPanelCard" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="MinHeight" Value="500" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="12" ShadowDepth="1" Opacity="0.06" Color="{DynamicResource Theme.Shadow}" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardPanelTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <!-- Legacy alias — use StatCounterCard / SoListStatCard for dashboard and list KPI counters -->
    <Style x:Key="DashboardKpiCard" TargetType="Border" BasedOn="{StaticResource SoListStatCard}" />

    <Style x:Key="DashboardTabControl" TargetType="TabControl">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{DynamicResource PanelMutedBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                                Padding="4,4,4,0">
                            <TabPanel IsItemsHost="True" Background="Transparent" />
                        </Border>
                        <Border Grid.Row="1" Background="{DynamicResource CardBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                Padding="10" Margin="0,0,0,0">
                            <ContentPresenter ContentSource="SelectedContent" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardTabItem" TargetType="TabItem">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Margin" Value="0,0,4,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="TabBorder" Background="Transparent" BorderThickness="0,0,0,2"
                            BorderBrush="Transparent" Padding="{TemplateBinding Padding}" Margin="{TemplateBinding Margin}">
                        <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource CardBrush}" />
                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource AccentLightBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardQuickLinkCardButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,10,10" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="CardBd" Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12" Padding="14,12"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="3" Direction="270"
                                              Opacity="0.14" Color="#55000000" />
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="AccentStripe" Grid.Column="0" CornerRadius="3" Margin="0,4,10,4"
                                    Background="{Binding AccentColor, Converter={StaticResource HexToBrushConverter}}" />
                            <Border x:Name="IconHost" Grid.Column="1" Width="48" Height="48"
                                    CornerRadius="12" Margin="0,0,14,0"
                                    Background="{DynamicResource CardBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270"
                                                      Opacity="0.1" Color="#44000000" />
                                </Border.Effect>
                                <TextBlock Style="{StaticResource IconText}" FontSize="22"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                           Foreground="{Binding AccentColor, Converter={StaticResource HexToBrushConverter}}"
                                           Text="{Binding IconGlyph}" />
                            </Border>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock x:Name="TitleText" Text="{Binding Title}"
                                           FontWeight="SemiBold" FontSize="13"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Subtitle}" FontSize="11" Margin="0,4,0,0"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CardBd" Property="Background" Value="{DynamicResource AccentLightBrush}" />
                            <Setter TargetName="CardBd" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            <Setter TargetName="CardBd" Property="BorderThickness" Value="1" />
                            <Setter TargetName="CardBd" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="22" ShadowDepth="5" Direction="270"
                                                      Opacity="0.22" Color="#66000000" />
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="IconHost" Property="Background" Value="{DynamicResource AccentLightBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="CardBd" Property="Background" Value="{DynamicResource PanelMutedBrush}" />
                            <Setter TargetName="CardBd" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            <Setter TargetName="CardBd" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270"
                                                      Opacity="0.1" Color="#33000000" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="CardBd" Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FormLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <Style x:Key="FormInput" TargetType="TextBox">
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{DynamicResource CardBrush}" />
    </Style>

    <Style x:Key="FormCombo" TargetType="ComboBox">
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="Background" Value="{DynamicResource CardBrush}" />
    </Style>

    <!-- Sub-page shared compact typography & controls -->
    <Style x:Key="SubPageCompactTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style x:Key="SubPageCompactSubtitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style x:Key="SubPageIconHost" TargetType="Border">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="{DynamicResource AccentLightBrush}" />
    </Style>
    <Style x:Key="SubPageFormLabel" TargetType="TextBlock" BasedOn="{StaticResource FormLabel}">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Margin" Value="0,0,0,3" />
    </Style>
    <Style x:Key="SubPageFormInput" TargetType="TextBox" BasedOn="{StaticResource FormInput}">
        <Setter Property="Height" Value="26" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="5,3" />
    </Style>
    <Style x:Key="SubPageFormMultiline" TargetType="TextBox" BasedOn="{StaticResource SubPageFormInput}">
        <Setter Property="Height" Value="52" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
    </Style>
    <Style x:Key="SubPageFormCombo" TargetType="ComboBox" BasedOn="{StaticResource FormCombo}">
        <Setter Property="Height" Value="26" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="5,3" />
    </Style>
    <Style x:Key="SubPageSectionHeader" TargetType="TextBlock" BasedOn="{StaticResource SectionHeader}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Margin" Value="0,6,0,4" />
    </Style>
    <Style x:Key="SubPageFieldCell" TargetType="StackPanel">
        <Setter Property="Margin" Value="0,0,8,6" />
    </Style>
    <Style x:Key="DynamicFormFieldCell" TargetType="Border">
        <Setter Property="MinWidth" Value="148" />
        <Setter Property="Width" Value="172" />
        <Setter Property="Margin" Value="0,0,10,8" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="VerticalAlignment" Value="Top" />
    </Style>
    <Style x:Key="SubPageFooterNote" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button">
        <Style.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="White" />
            </Style>
        </Style.Resources>
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          RecognizesAccessKey="True"
                                          TextElement.Foreground="White" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentHoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource CardBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PanelMutedBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ActionButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Style.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="White" />
            </Style>
        </Style.Resources>
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="DeleteActionButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
        <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
        <Setter Property="Background" Value="{DynamicResource DangerLightBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DangerBorderBrush}" />
    </Style>

    <Style x:Key="DangerIconButton" TargetType="Button">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="FontFamily" Value="{StaticResource IconFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
        <Setter Property="Background" Value="{DynamicResource DangerLightBrush}" />
