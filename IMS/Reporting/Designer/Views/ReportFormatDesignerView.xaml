<UserControl x:Class="IMS.Reporting.Designer.Views.ReportFormatDesignerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:IMS.Views.Controls"
             xmlns:conv="clr-namespace:IMS.Converters"
             xmlns:vm="clr-namespace:IMS.Reporting.Designer.ViewModels"
             Background="#dce4ec">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisInvert" Invert="True" />
        <conv:HexToBrushConverter x:Key="HexToBrush" />
    </UserControl.Resources>
    <controls:TransactionEntryShell Title="{Binding PageTitle}">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#2c3e50" Padding="8,6" Margin="0,0,0,8">
                <WrapPanel>
                    <Button Style="{StaticResource PrimaryButton}" Content="Save" Command="{Binding SaveCommand}" Margin="0,0,6,4" Padding="12,4" />
                    <Button Style="{StaticResource SecondaryButton}" Content="Close" Command="{Binding CloseCommand}" Margin="0,0,12,4" Padding="12,4" />
                    <Button Style="{StaticResource ActionButton}" Content="+ Text" Command="{Binding AddTextCommand}" Margin="0,0,4,4" Padding="8,4" />
                    <Button Style="{StaticResource ActionButton}" Content="+ Dynamic" Command="{Binding AddDynamicTextCommand}" Margin="0,0,4,4" Padding="8,4" />
                    <Button Style="{StaticResource ActionButton}" Content="+ Table" Command="{Binding AddTableCommand}" Margin="0,0,4,4" Padding="8,4" />
                    <Button Style="{StaticResource ActionButton}" Content="Undo" Command="{Binding UndoCommand}" Margin="0,0,4,4" Padding="8,4" />
                    <Button Style="{StaticResource ActionButton}" Content="Redo" Command="{Binding RedoCommand}" Margin="0,0,4,4" Padding="8,4" />
                    <Button Style="{StaticResource ActionButton}" Content="Delete" Command="{Binding DeleteSelectedCommand}" Margin="0,0,4,4" Padding="8,4" />
                    <Button Style="{StaticResource ActionButton}" Content="Tax invoice layout" Command="{Binding ResetStandardLayoutCommand}" Margin="0,0,12,4" Padding="8,4"
                            ToolTip="Sales invoice: Raj Cloth tax invoice template. Other types: standard layout." />
                    <TextBlock Text="Zoom" Foreground="#e2e8f0" VerticalAlignment="Center" Margin="0,0,6,4" />
                    <Slider Width="120" Minimum="0.5" Maximum="2" Value="{Binding Zoom}" VerticalAlignment="Center" Margin="0,0,8,4" />
                    <TextBlock Text="{Binding FormatName}" Foreground="#cbd5e1" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,4" />
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#94a3b8" VerticalAlignment="Center" FontSize="11" Margin="0,0,0,4" />
                </WrapPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="200" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" BorderBrush="#94a3b8" BorderThickness="1" Margin="0,0,8,0" Padding="8">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                            <TextBlock Text="Paper size (optional)" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <TextBlock Text="Preset" FontSize="11" Foreground="#64748b" />
                            <ComboBox Margin="0,2,0,6" Style="{StaticResource SubPageFormCombo}"
                                      ItemsSource="{Binding PaperSizes}"
                                      SelectedValuePath="Key" DisplayMemberPath="DisplayLabel"
                                      SelectedValue="{Binding SelectedPaperSizeKey}" />
                            <CheckBox Content="Custom dimensions" IsChecked="{Binding UseCustomPaper}" Margin="0,0,0,6" />
                            <StackPanel Visibility="{Binding UseCustomPaper, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Width (mm)" FontSize="11" />
                                <TextBox Text="{Binding CustomWidthMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,4" />
                                <TextBlock Text="Height (mm)" FontSize="11" />
                                <TextBox Text="{Binding CustomHeightMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,4" />
                                <TextBlock Text="Margins (mm)" FontSize="11" Margin="0,4,0,2" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBox Grid.Row="0" Grid.Column="0" ToolTip="Top"
                                             Text="{Binding MarginTopMm, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="0" Grid.Column="2" ToolTip="Right"
                                             Text="{Binding MarginRightMm, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="1" Grid.Column="0" ToolTip="Bottom" Margin="0,4,0,0"
                                             Text="{Binding MarginBottomMm, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="1" Grid.Column="2" ToolTip="Left" Margin="0,4,0,0"
                                             Text="{Binding MarginLeftMm, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </StackPanel>
                            <TextBlock Text="{Binding PageSizeLabel}" FontSize="11" Foreground="#475569" Margin="0,6,0,0" />
                        </StackPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Field explorer" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <ListBox x:Name="FieldList" ItemsSource="{Binding FieldExplorer}" DisplayMemberPath="DisplayLabel"
                                 MouseDoubleClick="FieldExplorer_OnDoubleClick" />
                    </DockPanel>
                </Border>

                <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              Background="#94a3b8" Padding="16">
                    <Viewbox x:Name="ZoomHost" Stretch="None">
                        <Canvas x:Name="DesignCanvas"
                                Width="{Binding DesignCanvasWidth}"
                                Height="{Binding DesignCanvasHeight}"
                                Background="White"
                                MouseLeftButtonDown="Canvas_OnMouseLeftButtonDown"
                                MouseMove="Canvas_OnMouseMove"
                                MouseLeftButtonUp="Canvas_OnMouseLeftButtonUp" />
                    </Viewbox>
                </ScrollViewer>

                <Border Grid.Column="2" Background="White" BorderBrush="#94a3b8" BorderThickness="1" Margin="8,0,0,0" Padding="8">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Properties" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBlock DockPanel.Dock="Top" Text="Select an element on the canvas."
                                   FontSize="11" Foreground="#64748b" Margin="0,0,0,8"
                                   Visibility="{Binding HasSelectedElement, Converter={StaticResource BoolToVisInvert}}" />
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding HasSelectedElement, Converter={StaticResource BoolToVis}}">
                            <StackPanel DataContext="{Binding SelectedElement}">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,2" />
                                <TextBlock Text="{Binding Type}" FontSize="10" Foreground="#64748b" Margin="0,0,0,10" />
                                <TextBlock Text="Position &amp; size" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <TextBlock Text="X (mm)" FontSize="11" />
                                <TextBox Text="{Binding XMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,6" />
                                <TextBlock Text="Y (mm)" FontSize="11" />
                                <TextBox Text="{Binding YMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,6" />
                                <TextBlock Text="Width (mm)" FontSize="11" />
                                <TextBox Text="{Binding WidthMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,6" />
                                <TextBlock Text="Height (mm)" FontSize="11" />
                                <TextBox Text="{Binding HeightMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" />
                                <StackPanel Visibility="{Binding SupportsFieldColors, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Colors" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4" />
                                    <TextBlock Text="Text color (hex)" FontSize="11" Foreground="#64748b" />
                                    <Grid Margin="0,2,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="28" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding TextColor, UpdateSourceTrigger=PropertyChanged}" ToolTip="e.g. #0f172a — leave empty for theme default" />
                                        <Border Grid.Column="1" Width="24" Height="20" Margin="4,0,0,0" BorderBrush="#94a3b8" BorderThickness="1"
                                                Background="{Binding TextColor, Converter={StaticResource HexToBrush}}" />
                                    </Grid>
                                    <TextBlock Text="Background (hex)" FontSize="11" Foreground="#64748b" />
                                    <Grid Margin="0,2,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="28" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding BackgroundColor, UpdateSourceTrigger=PropertyChanged}" ToolTip="e.g. #f8fafc — leave empty for transparent" />
                                        <Border Grid.Column="1" Width="24" Height="20" Margin="4,0,0,0" BorderBrush="#94a3b8" BorderThickness="1"
                                                Background="{Binding BackgroundColor, Converter={StaticResource HexToBrush}}" />
                                    </Grid>
                                    <TextBlock Text="Font size (pt)" FontSize="11" />
                                    <TextBox Text="{Binding FontSizePt, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,6" />
                                    <TextBlock Text="Text align" FontSize="11" />
                                    <ComboBox Margin="0,2,0,10" SelectedValue="{Binding TextAlign}" SelectedValuePath="Content">
                                        <ComboBoxItem Content="left" />
                                        <ComboBoxItem Content="center" />
                                        <ComboBoxItem Content="right" />
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Visibility="{Binding IsTable, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Table header colors" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4" />
                                    <TextBlock Text="Header background" FontSize="11" Foreground="#64748b" />
                                    <Grid Margin="0,2,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="28" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding HeaderBackgroundColor, UpdateSourceTrigger=PropertyChanged}" ToolTip="e.g. #5c4033" />
                                        <Border Grid.Column="1" Width="24" Height="20" Margin="4,0,0,0" BorderBrush="#94a3b8" BorderThickness="1"
                                                Background="{Binding HeaderBackgroundColor, Converter={StaticResource HexToBrush}}" />
                                    </Grid>
                                    <TextBlock Text="Header text" FontSize="11" Foreground="#64748b" />
                                    <Grid Margin="0,2,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="28" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding HeaderTextColor, UpdateSourceTrigger=PropertyChanged}" ToolTip="e.g. #ffffff" />
                                        <Border Grid.Column="1" Width="24" Height="20" Margin="4,0,0,0" BorderBrush="#94a3b8" BorderThickness="1"
                                                Background="{Binding HeaderTextColor, Converter={StaticResource HexToBrush}}" />
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </controls:TransactionEntryShell>
</UserControl>
