# IMS Docker Compose / Coolify environment
# Copy to .env for local testing: cp .env.example .env

# Public URL (no trailing slash)
IMS_PUBLIC_URL=http://ims.144.91.98.218.nip.io

# Required — generate: openssl rand -hex 32
IMS_AUTH_SECRET=change-me-generate-with-openssl-rand-hex-32

# Leave empty — nginx proxies /api to the api container (same-origin)
VITE_API_BASE_URL=

# Root path for React assets (use / for Docker/Coolify)
VITE_BASE_PATH=/

# Coolify Traefik hostname for the web service
SERVICE_FQDN_WEB_80=ims.144.91.98.218.nip.io
