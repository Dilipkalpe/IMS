PORT=3000

# Local MongoDB Server (requires mongod running — Compass alone is not enough):
# MONGODB_URI=mongodb://127.0.0.1:27017/ims

# MongoDB Atlas (recommended if you only have Compass — copy from Compass connection):
# MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/ims?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/ims
